---
const title = 'Radio Bubble Full Video Export';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
	</head>
	<body>
		<main class="video-stage" aria-label={title}>
			<div class="skyview" data-video-skyview></div>
			<canvas class="copy-overlay-canvas" data-video-overlay-canvas aria-hidden="true"></canvas>
			<div class="copy-overlay" data-video-overlay>
				<p class="copy-overlay__eyebrow" data-video-overlay-eyebrow></p>
				<p class="copy-overlay__title" data-video-overlay-title></p>
				<p class="copy-overlay__body" data-video-overlay-body></p>
			</div>
		</main>

		<script>
			import { mountRadioBubbleViewer } from '../../scripts/radio-bubble-viewer.js';
			import {
				DEFAULT_RADIO_BUBBLE_VIDEO_LAYOUT_ID,
				getRadioBubbleVideoLayout,
			} from '../../scripts/radio-bubble-video-layouts.js';
			import {
				getRadioBubbleVideoCamera,
				getRadioBubbleVideoCue,
				getRadioBubbleVideoCueOpacity,
				RADIO_BUBBLE_VIDEO_DURATION_SECS,
			} from '../../scripts/radio-bubble-video-timeline.js';
			import { createJourneyEvaluator } from '../../scripts/journey-evaluator.js';

			const FRAME_TIMEOUT_MS = 45_000;
			const INITIAL_TIMEOUT_MS = 90_000;
			const ARTIFACT_PLATES = Object.freeze(['composite', 'sky', 'overlay']);

			const mount = document.querySelector('[data-video-skyview]');
			const overlay = document.querySelector('[data-video-overlay]');
			const overlayEyebrow = document.querySelector('[data-video-overlay-eyebrow]');
			const overlayTitle = document.querySelector('[data-video-overlay-title]');
			const overlayBody = document.querySelector('[data-video-overlay-body]');
			const overlayCanvas = document.querySelector('[data-video-overlay-canvas]');
			const compositeCanvas = document.createElement('canvas');
			const compositeContext = compositeCanvas.getContext('2d', { alpha: false });
			const routeParams = new URLSearchParams(window.location.search);
			const requestedLayoutId = routeParams.get('layout')
				?? (routeParams.get('videoScale') === '0.5' ? 'landscape-1080p' : DEFAULT_RADIO_BUBBLE_VIDEO_LAYOUT_ID);
			const layout = getRadioBubbleVideoLayout(requestedLayoutId)
				?? getRadioBubbleVideoLayout(DEFAULT_RADIO_BUBBLE_VIDEO_LAYOUT_ID);
			const preserveDrawingBuffer = routeParams.get('preserveDrawingBuffer') === '1';
			const showCanvasOverlay = routeParams.get('canvasOverlay') === '1';
			const injectedJourney = window.__fisJourneyInput && typeof window.__fisJourneyInput === 'object'
				? window.__fisJourneyInput
				: null;
			const journeyEvaluator = injectedJourney?.format === 'fis-journey-v1'
				? createJourneyEvaluator(injectedJourney)
				: null;
			const activeDurationSecs = journeyEvaluator?.durationSecs ?? RADIO_BUBBLE_VIDEO_DURATION_SECS;
			const activeCues = Array.isArray(journeyEvaluator?.journey?.cues) && journeyEvaluator.journey.cues.length > 0
				? journeyEvaluator.journey.cues
				: null;
			document.documentElement.dataset.videoLayout = layout.id;
			document.documentElement.toggleAttribute('data-canvas-overlay', showCanvasOverlay);

			let mounted = null;
			let manualTimeMs = 0;

			const starReadiness = {
				commitCount: 0,
				lastCommit: null,
				lastSignature: null,
				pendingSignature: null,
				waiters: new Set(),
			};
			const expectedStarCountCache = new Map();

			const exportApi = {
				ready: null,
				readyState: 'loading',
				error: null,
				getStatus,
				startClip,
				captureFrame,
				captureFrameArtifacts,
				getCanvasInfo,
				captureCanvasBlob,
				captureCanvasBlobDataUrl,
				captureCompositeBlob,
				captureCompositeBlobDataUrl,
				recordCanvasStream,
			};
			window.__radioBubbleVideoExport = exportApi;

			function applyOverlayLayout() {
				const rootStyle = document.documentElement.style;
				const text = layout.text;
				rootStyle.setProperty('--video-overlay-x', `${text.x}px`);
				rootStyle.setProperty('--video-overlay-bottom', `${text.bottom}px`);
				rootStyle.setProperty('--video-overlay-max-width', `${text.maxWidth}px`);
				rootStyle.setProperty('--video-overlay-title-max-width', `${text.titleMaxWidth ?? text.maxWidth}px`);
				rootStyle.setProperty('--video-overlay-body-max-width', `${text.bodyMaxWidth ?? text.maxWidth}px`);
				rootStyle.setProperty('--video-overlay-eyebrow-font-size', `${text.eyebrowFontSize}px`);
				rootStyle.setProperty('--video-overlay-title-font-size', `${text.titleFontSize}px`);
				rootStyle.setProperty('--video-overlay-body-font-size', `${text.bodyFontSize}px`);
				rootStyle.setProperty('--video-overlay-eyebrow-gap', `${text.eyebrowGap}px`);
				rootStyle.setProperty('--video-overlay-body-gap', `${text.bodyGap}px`);
				rootStyle.setProperty('--video-overlay-title-line-height', String(text.titleLineHeight));
				rootStyle.setProperty('--video-overlay-body-line-height', String(text.bodyLineHeight));
				rootStyle.setProperty('--video-overlay-shadow-blur', `${text.shadowBlur}px`);
				rootStyle.setProperty('--video-overlay-shadow-offset-y', `${text.shadowOffsetY}px`);
			}

			applyOverlayLayout();

			function getStarStats() {
				const stats = mounted?.starLayer?.getStats?.() ?? {};
				return {
					nodeCount: Number(stats.nodeCount ?? 0),
					starCount: Number(stats.starCount ?? 0),
					loadGeneration: Number(stats.loadGeneration ?? 0),
				};
			}

			function getCanvas() {
				const canvas = mounted?.viewer?.canvas ?? mount?.querySelector?.('canvas');
				if (!(canvas instanceof HTMLCanvasElement)) {
					throw new Error('Radio bubble export canvas is not available.');
				}
				return canvas;
			}

			function getOverlayCanvas() {
				if (!(overlayCanvas instanceof HTMLCanvasElement)) {
					throw new Error('Radio bubble overlay canvas is not available.');
				}
				return overlayCanvas;
			}

			function syncCanvasSize(targetCanvas, sourceCanvas) {
				if (targetCanvas.width !== sourceCanvas.width) {
					targetCanvas.width = sourceCanvas.width;
				}
				if (targetCanvas.height !== sourceCanvas.height) {
					targetCanvas.height = sourceCanvas.height;
				}
			}

			function syncOverlayCanvas() {
				const sourceCanvas = getCanvas();
				const targetCanvas = getOverlayCanvas();
				syncCanvasSize(targetCanvas, sourceCanvas);
				return targetCanvas;
			}

			function getCanvasInfo() {
				const canvas = getCanvas();
				const currentOverlayCanvas = syncOverlayCanvas();
				syncCanvasSize(compositeCanvas, canvas);
				return {
					width: canvas.width,
					height: canvas.height,
					clientWidth: canvas.clientWidth,
					clientHeight: canvas.clientHeight,
					overlayWidth: currentOverlayCanvas.width,
					overlayHeight: currentOverlayCanvas.height,
					compositeWidth: compositeCanvas.width,
					compositeHeight: compositeCanvas.height,
					layout: {
						id: layout.id,
						width: layout.width,
						height: layout.height,
					},
					durationSecs: activeDurationSecs,
					preserveDrawingBuffer,
					showCanvasOverlay,
					captureStreamSupported: typeof canvas.captureStream === 'function',
					mediaRecorderSupported: typeof MediaRecorder !== 'undefined',
					journey: journeyEvaluator
						? {
							format: journeyEvaluator.journey.format,
							id: journeyEvaluator.journey.id,
							title: journeyEvaluator.journey.title,
						}
						: null,
				};
			}

			function wrapCanvasText(context, text, maxWidth) {
				const words = String(text ?? '').split(/\s+/).filter(Boolean);
				const lines = [];
				let line = '';
				for (const word of words) {
					const candidate = line ? `${line} ${word}` : word;
					if (line && context.measureText(candidate).width > maxWidth) {
						lines.push(line);
						line = word;
					} else {
						line = candidate;
					}
				}
				if (line) {
					lines.push(line);
				}
				return lines;
			}

			function drawTextLines(context, lines, x, y, lineHeight) {
				let nextY = y;
				for (const line of lines) {
					context.fillText(line, x, nextY);
					nextY += lineHeight;
				}
				return nextY;
			}

			function drawCanvasOverlay(cue, opacity) {
				const canvas = syncOverlayCanvas();
				const context = canvas.getContext('2d');
				if (!context) {
					return;
				}

				context.clearRect(0, 0, canvas.width, canvas.height);
				if (!cue || opacity <= 0) {
					return;
				}

				const scaleX = canvas.width / layout.width;
				const scaleY = canvas.height / layout.height;
				const textScale = Math.min(scaleX, scaleY);
				const text = layout.text;
				const x = text.x * scaleX;
				const maxWidth = text.maxWidth * scaleX;
				const titleMaxWidth = (text.titleMaxWidth ?? text.maxWidth) * scaleX;
				const bodyMaxWidth = (text.bodyMaxWidth ?? text.maxWidth) * scaleX;
				const eyebrowFontSize = text.eyebrowFontSize * textScale;
				const titleFontSize = text.titleFontSize * textScale;
				const bodyFontSize = text.bodyFontSize * textScale;
				const eyebrowGap = text.eyebrowGap * textScale;
				const bodyGap = text.bodyGap * textScale;
				const titleLineHeight = titleFontSize * text.titleLineHeight;
				const bodyLineHeight = bodyFontSize * text.bodyLineHeight;

				context.save();
				context.globalAlpha = opacity;
				context.textBaseline = 'top';
				context.textAlign = 'left';
				context.shadowColor = 'rgba(0, 0, 0, 0.78)';
				context.shadowBlur = text.shadowBlur * textScale;
				context.shadowOffsetY = text.shadowOffsetY * textScale;

				context.font = `750 ${titleFontSize}px Inter, ui-sans-serif, system-ui, sans-serif`;
				const titleLines = wrapCanvasText(context, cue.title, Math.min(maxWidth, titleMaxWidth));
				context.font = `450 ${bodyFontSize}px Inter, ui-sans-serif, system-ui, sans-serif`;
				const bodyLines = wrapCanvasText(context, cue.body, Math.min(maxWidth, bodyMaxWidth));
				const blockHeight = eyebrowFontSize * 1.1
					+ eyebrowGap
					+ titleLines.length * titleLineHeight
					+ bodyGap
					+ bodyLines.length * bodyLineHeight;
				let y = canvas.height - (text.bottom * scaleY) - blockHeight;

				context.fillStyle = '#8fd5ff';
				context.font = `700 ${eyebrowFontSize}px Inter, ui-sans-serif, system-ui, sans-serif`;
				context.fillText(String(cue.eyebrow ?? '').toUpperCase(), x, y);
				y += eyebrowFontSize * 1.1 + eyebrowGap;

				context.fillStyle = '#f7fbff';
				context.font = `750 ${titleFontSize}px Inter, ui-sans-serif, system-ui, sans-serif`;
				y = drawTextLines(context, titleLines, x, y, titleLineHeight) + bodyGap;

				context.fillStyle = 'rgba(236, 244, 255, 0.88)';
				context.font = `450 ${bodyFontSize}px Inter, ui-sans-serif, system-ui, sans-serif`;
				drawTextLines(context, bodyLines, x, y, bodyLineHeight);
				context.restore();
			}

			function renderCompositeFrame() {
				const sourceCanvas = getCanvas();
				const currentOverlayCanvas = syncOverlayCanvas();
				syncCanvasSize(compositeCanvas, sourceCanvas);
				if (!compositeContext) {
					throw new Error('Could not create composite canvas context.');
				}
				compositeContext.fillStyle = '#02040b';
				compositeContext.fillRect(0, 0, compositeCanvas.width, compositeCanvas.height);
				compositeContext.drawImage(sourceCanvas, 0, 0, compositeCanvas.width, compositeCanvas.height);
				compositeContext.drawImage(currentOverlayCanvas, 0, 0, compositeCanvas.width, compositeCanvas.height);
				return compositeCanvas;
			}

			function canvasToBlob(canvas, type, quality) {
				return new Promise((resolve, reject) => {
					try {
						canvas.toBlob((blob) => {
							if (blob) {
								resolve(blob);
							} else {
								reject(new Error('Canvas toBlob returned null.'));
							}
						}, type, quality);
					} catch (error) {
						reject(error);
					}
				});
			}

			function blobToDataUrl(blob) {
				return new Promise((resolve, reject) => {
					const reader = new FileReader();
					reader.addEventListener('load', () => resolve(String(reader.result)));
					reader.addEventListener('error', () => reject(reader.error ?? new Error('Could not read blob.')));
					reader.readAsDataURL(blob);
				});
			}

			async function captureCanvasBlob(options = {}) {
				await exportApi.ready;
				const canvas = getCanvas();
				const type = options.type ?? 'image/png';
				const quality = Number.isFinite(options.quality) ? options.quality : undefined;
				const startedAt = performance.now();
				const blob = await canvasToBlob(canvas, type, quality);
				return {
					width: canvas.width,
					height: canvas.height,
					type: blob.type,
					size: blob.size,
					encodeMs: performance.now() - startedAt,
					preserveDrawingBuffer,
				};
			}

			async function captureCanvasBlobDataUrl(options = {}) {
				await exportApi.ready;
				const canvas = getCanvas();
				const type = options.type ?? 'image/png';
				const quality = Number.isFinite(options.quality) ? options.quality : undefined;
				const encodeStartedAt = performance.now();
				const blob = await canvasToBlob(canvas, type, quality);
				const encodeMs = performance.now() - encodeStartedAt;
				const readStartedAt = performance.now();
				const dataUrl = await blobToDataUrl(blob);
				return {
					width: canvas.width,
					height: canvas.height,
					type: blob.type,
					size: blob.size,
					encodeMs,
					readMs: performance.now() - readStartedAt,
					preserveDrawingBuffer,
					dataUrl,
				};
			}

			async function captureCompositeBlob(options = {}) {
				await exportApi.ready;
				const canvas = renderCompositeFrame();
				const type = options.type ?? 'image/png';
				const quality = Number.isFinite(options.quality) ? options.quality : undefined;
				const startedAt = performance.now();
				const blob = await canvasToBlob(canvas, type, quality);
				return {
					width: canvas.width,
					height: canvas.height,
					type: blob.type,
					size: blob.size,
					encodeMs: performance.now() - startedAt,
					preserveDrawingBuffer,
					composited: true,
				};
			}

			async function captureCompositeBlobDataUrl(options = {}) {
				await exportApi.ready;
				const canvas = renderCompositeFrame();
				const type = options.type ?? 'image/png';
				const quality = Number.isFinite(options.quality) ? options.quality : undefined;
				const encodeStartedAt = performance.now();
				const blob = await canvasToBlob(canvas, type, quality);
				const encodeMs = performance.now() - encodeStartedAt;
				const readStartedAt = performance.now();
				const dataUrl = await blobToDataUrl(blob);
				return {
					width: canvas.width,
					height: canvas.height,
					type: blob.type,
					size: blob.size,
					encodeMs,
					readMs: performance.now() - readStartedAt,
					preserveDrawingBuffer,
					composited: true,
					dataUrl,
				};
			}

			function normalizeRequestedPlates(plates) {
				if (plates === 'all') {
					return [...ARTIFACT_PLATES];
				}
				if (Array.isArray(plates)) {
					const requested = plates.filter((plate) => ARTIFACT_PLATES.includes(plate));
					return requested.length > 0 ? requested : ['composite'];
				}
				return ['composite'];
			}

			function getPlateCanvas(plate) {
				if (plate === 'sky') {
					return getCanvas();
				}
				if (plate === 'overlay') {
					return syncOverlayCanvas();
				}
				return renderCompositeFrame();
			}

			async function captureCanvasDataUrl(canvas, options = {}) {
				const type = options.type ?? 'image/png';
				const quality = Number.isFinite(options.quality) ? options.quality : undefined;
				const encodeStartedAt = performance.now();
				const blob = await canvasToBlob(canvas, type, quality);
				const encodeMs = performance.now() - encodeStartedAt;
				const readStartedAt = performance.now();
				const dataUrl = await blobToDataUrl(blob);
				return {
					width: canvas.width,
					height: canvas.height,
					type: blob.type,
					size: blob.size,
					encodeMs,
					readMs: performance.now() - readStartedAt,
					dataUrl,
				};
			}

			async function captureFrameArtifacts(options = {}) {
				await exportApi.ready;
				const stats = await captureFrame(options);
				const requestedPlates = normalizeRequestedPlates(options.plates);
				const type = options.type ?? 'image/png';
				const quality = Number.isFinite(options.quality) ? options.quality : undefined;
				const artifacts = {};

				for (const plate of requestedPlates) {
					const artifactType = plate === 'overlay' ? 'image/png' : type;
					const canvas = getPlateCanvas(plate);
					artifacts[plate] = await captureCanvasDataUrl(canvas, {
						type: artifactType,
						quality,
					});
				}

				return {
					stats,
					artifacts,
				};
			}

			function getMediaRecorderType(preferredType) {
				if (typeof MediaRecorder === 'undefined') {
					throw new Error('MediaRecorder is not available in this browser.');
				}
				const candidates = [
					preferredType,
					'video/webm;codecs=vp9',
					'video/webm;codecs=vp8',
					'video/webm',
					'video/mp4',
				].filter(Boolean);
				return candidates.find((type) => MediaRecorder.isTypeSupported(type)) ?? '';
			}

			function notifyCommitWaiters() {
				for (const waiter of starReadiness.waiters) {
					waiter();
				}
			}

			function onStarFieldCommit(commit) {
				const stats = commit?.stats ?? {};
				starReadiness.commitCount += 1;
				starReadiness.lastCommit = {
					starCount: Number(commit?.starCount ?? stats.starCount ?? 0),
					nodeCount: Number(commit?.nodeCount ?? stats.nodeCount ?? 0),
					loadGeneration: Number(commit?.loadGeneration ?? stats.loadGeneration ?? 0),
					timeMs: performance.now(),
				};
				starReadiness.lastSignature = starReadiness.pendingSignature ?? starReadiness.lastSignature;
				notifyCommitWaiters();
			}

			function selectionSignature(selection) {
				const nodes = Array.isArray(selection?.nodes) ? selection.nodes : [];
				return nodes
					.map((node) => node?.nodeKey ?? `${node?.payloadOffset ?? 'none'}:${node?.payloadLength ?? 0}`)
					.join('|');
			}

			function getPayloadNodes(selection) {
				return (Array.isArray(selection?.nodes) ? selection.nodes : [])
					.filter((node) => node && node.payloadLength > 0);
			}

			async function computeExpectedStarCount(nodes, signature) {
				if (expectedStarCountCache.has(signature)) {
					return {
						expectedStarCount: expectedStarCountCache.get(signature),
						cacheHit: true,
					};
				}

				if (!Array.isArray(nodes) || nodes.length === 0) {
					expectedStarCountCache.set(signature, 0);
					return {
						expectedStarCount: 0,
						cacheHit: false,
					};
				}

				const renderService = mounted.datasetSession.getRenderService();
				const entries = await renderService.fetchNodePayloadBatch(nodes);
				let expectedStarCount = 0;
				for (const entry of entries) {
					const decoded = renderService.decodePayload(entry.buffer, entry.node);
					expectedStarCount += Number(decoded?.count ?? 0);
				}
				expectedStarCountCache.set(signature, expectedStarCount);
				return {
					expectedStarCount,
					cacheHit: false,
				};
			}

			function currentCommitMatches(signature, expectedStarCount) {
				const stats = getStarStats();
				if (stats.starCount !== expectedStarCount) {
					return false;
				}
				if (starReadiness.lastSignature === signature) {
					return true;
				}
				if (starReadiness.lastSignature == null && starReadiness.pendingSignature === signature) {
					starReadiness.lastSignature = signature;
					return true;
				}
				return false;
			}

			function createReadinessError(details) {
				const stats = getStarStats();
				const sceneTime = Number.isFinite(details.sceneTimeSecs)
					? details.sceneTimeSecs.toFixed(3)
					: 'unknown';
				return new Error(
					`Radio bubble frame readiness timeout: frame=${details.frameIndex} expected=${details.expectedStarCount} actual=${stats.starCount} nodeCount=${details.nodeCount} committedNodeCount=${stats.nodeCount} sceneTime=${sceneTime}s`,
				);
			}

			function waitForCommittedStars(details) {
				const {
					signature,
					expectedStarCount,
					timeoutMs = FRAME_TIMEOUT_MS,
				} = details;

				if (currentCommitMatches(signature, expectedStarCount)) {
					return Promise.resolve(getStarStats());
				}

				return new Promise((resolve, reject) => {
					let done = false;
					let timeoutId = null;

					function finish(callback, value) {
						if (done) return;
						done = true;
						clearTimeout(timeoutId);
						starReadiness.waiters.delete(check);
						callback(value);
					}

					function check() {
						if (currentCommitMatches(signature, expectedStarCount)) {
							finish(resolve, getStarStats());
						}
					}

					timeoutId = window.setTimeout(() => {
						finish(reject, createReadinessError(details));
					}, timeoutMs);
					starReadiness.waiters.add(check);
					check();
				});
			}

			function getActiveCue(sceneTimeSecs) {
				if (activeCues) {
					return activeCues.find((entry) => sceneTimeSecs >= entry.startSecs && sceneTimeSecs < entry.endSecs)
						?? activeCues[activeCues.length - 1];
				}
				return getRadioBubbleVideoCue(sceneTimeSecs);
			}

			function getActiveCueOpacity(sceneTimeSecs, fadeSecs = 0.85) {
				if (!activeCues) {
					return getRadioBubbleVideoCueOpacity(sceneTimeSecs, fadeSecs);
				}
				const cue = getActiveCue(sceneTimeSecs);
				const localTime = sceneTimeSecs - cue.startSecs;
				const fadeIn = Math.min(1, Math.max(0, localTime / fadeSecs));
				const fadeOut = Math.min(1, Math.max(0, (cue.endSecs - sceneTimeSecs) / fadeSecs));
				return Math.min(fadeIn, fadeOut);
			}

			function getActiveCamera(sceneTimeSecs) {
				return journeyEvaluator
					? journeyEvaluator.evaluate(sceneTimeSecs)
					: getRadioBubbleVideoCamera(sceneTimeSecs);
			}

			function updateOverlay(sceneTimeSecs) {
				const cue = getActiveCue(sceneTimeSecs);
				const opacity = getActiveCueOpacity(sceneTimeSecs);

				if (overlayEyebrow) overlayEyebrow.textContent = cue.eyebrow;
				if (overlayTitle) overlayTitle.textContent = cue.title;
				if (overlayBody) overlayBody.textContent = cue.body;
				if (overlay) overlay.style.opacity = String(opacity);
				drawCanvasOverlay(cue, opacity);
			}

			function applyCamera(sceneTimeSecs) {
				const { viewer, cameraController } = mounted;
				const nextCamera = getActiveCamera(sceneTimeSecs);
				cameraController.cancelAutomation();
				cameraController.rig.setPosition(nextCamera.observerPc);
				cameraController.rig.orientToward(nextCamera.targetPc, nextCamera.cameraUpPc);
				viewer.setState({
					observerPc: { ...nextCamera.observerPc },
					targetPc: { ...nextCamera.targetPc },
				});
			}

			function enterManualTimeline() {
				const runtime = mounted.viewer.runtime;
				mounted.viewer.stop();
				runtime.running = true;
				runtime.previousFrameTimeMs = null;
				runtime.startedAtTimeMs = 0;
				runtime.frameNumber = 0;
				manualTimeMs = 0;
			}

			function renderTimelineStep(deltaSecs = 0) {
				const runtime = mounted.viewer.runtime;
				manualTimeMs += Math.max(0, Number(deltaSecs) || 0) * 1000;
				runtime.frame(manualTimeMs);
			}

			async function settleStars({ frameIndex, sceneTimeSecs, timeoutMs = FRAME_TIMEOUT_MS }) {
				const startedAt = performance.now();
				const timings = {};
				const selectionStartedAt = performance.now();
				const selection = await mounted.viewer.refreshSelection();
				timings.selectionMs = performance.now() - selectionStartedAt;

				const payloadNodes = getPayloadNodes(selection);
				const signature = selectionSignature(selection);
				const expectedStartedAt = performance.now();
				const expected = await computeExpectedStarCount(payloadNodes, signature);
				timings.expectedMs = performance.now() - expectedStartedAt;
				const expectedStarCount = expected.expectedStarCount;
				starReadiness.pendingSignature = signature;

				const alreadyCommitted = currentCommitMatches(signature, expectedStarCount);
				const waitStartedAt = performance.now();
				let stats = getStarStats();
				if (!alreadyCommitted) {
					renderTimelineStep(0);
					stats = await waitForCommittedStars({
						frameIndex,
						sceneTimeSecs,
						signature,
						expectedStarCount,
						nodeCount: payloadNodes.length,
						timeoutMs,
					});
				}
				timings.commitWaitMs = performance.now() - waitStartedAt;

				const renderOnceStartedAt = performance.now();
				mounted.viewer.runtime.renderOnce();
				timings.renderOnceMs = performance.now() - renderOnceStartedAt;
				timings.totalMs = performance.now() - startedAt;

				return {
					frameIndex,
					sceneTimeSecs,
					expectedStarCount,
					actualStarCount: stats.starCount,
					nodeCount: payloadNodes.length,
					committedNodeCount: stats.nodeCount,
					loadGeneration: stats.loadGeneration,
					selectionMeta: selection.meta ?? {},
					expectedCacheHit: expected.cacheHit,
					expectedCacheSize: expectedStarCountCache.size,
					skippedCommitWait: alreadyCommitted,
					timings,
				};
			}

			function getStatus() {
				return {
					readyState: exportApi.readyState,
					error: exportApi.error,
					starStats: getStarStats(),
					commitCount: starReadiness.commitCount,
					lastCommit: starReadiness.lastCommit,
					layout: {
						id: layout.id,
						width: layout.width,
						height: layout.height,
					},
					durationSecs: activeDurationSecs,
					journey: journeyEvaluator
						? {
							format: journeyEvaluator.journey.format,
							id: journeyEvaluator.journey.id,
							title: journeyEvaluator.journey.title,
						}
						: null,
				};
			}

			async function startClip() {
				await exportApi.ready;
				enterManualTimeline();
				applyCamera(0);
				updateOverlay(0);
				renderTimelineStep(0);
				return settleStars({
					frameIndex: 0,
					sceneTimeSecs: 0,
					timeoutMs: INITIAL_TIMEOUT_MS,
				});
			}

			async function captureFrame({ frameIndex, timeSecs, deltaSecs }) {
				await exportApi.ready;
				const sceneTimeSecs = Number(timeSecs) || 0;
				applyCamera(sceneTimeSecs);
				updateOverlay(sceneTimeSecs);
				renderTimelineStep(deltaSecs);
				return settleStars({
					frameIndex,
					sceneTimeSecs,
				});
			}

			async function recordCanvasStream(options = {}) {
				await exportApi.ready;
				const useComposite = options.source === 'composite';
				const canvas = useComposite ? renderCompositeFrame() : getCanvas();
				if (typeof canvas.captureStream !== 'function') {
					throw new Error('Canvas captureStream() is not available in this browser.');
				}
				const stream = canvas.captureStream(0);
				const [track] = stream.getVideoTracks();
				if (!track || typeof track.requestFrame !== 'function') {
					stream.getTracks().forEach((entry) => entry.stop());
					throw new Error('CanvasCaptureMediaStreamTrack.requestFrame() is not available.');
				}

				const frameCount = Math.max(1, Math.floor(Number(options.frameCount) || 1));
				const fps = Math.max(1, Number(options.fps) || 24);
				const mimeType = getMediaRecorderType(options.mimeType);
				const recorderOptions = {};
				if (mimeType) {
					recorderOptions.mimeType = mimeType;
				}
				if (Number.isFinite(options.bitsPerSecond)) {
					recorderOptions.videoBitsPerSecond = options.bitsPerSecond;
				}

				const chunks = [];
				const recorder = new MediaRecorder(stream, recorderOptions);
				const stopped = new Promise((resolve, reject) => {
					recorder.addEventListener('dataavailable', (event) => {
						if (event.data && event.data.size > 0) {
							chunks.push(event.data);
						}
					});
					recorder.addEventListener('stop', resolve, { once: true });
					recorder.addEventListener('error', () => {
						reject(recorder.error ?? new Error('MediaRecorder failed.'));
					}, { once: true });
				});

				const timings = [];
				const startedAt = performance.now();
				recorder.start();
				try {
					for (let frameIndex = 1; frameIndex <= frameCount; frameIndex += 1) {
						const frameStartedAt = performance.now();
						const sceneTimeSecs = (frameIndex - 1) / fps;
						const deltaSecs = frameIndex === 1 ? 0 : 1 / fps;
						const stats = frameIndex === 1
							? await startClip()
							: await captureFrame({ frameIndex, timeSecs: sceneTimeSecs, deltaSecs });
						if (useComposite) {
							renderCompositeFrame();
						}
						const requestStartedAt = performance.now();
						track.requestFrame();
						timings.push({
							frameIndex,
							sceneTimeSecs,
							captureMs: requestStartedAt - frameStartedAt,
							requestFrameMs: performance.now() - requestStartedAt,
							routeMs: stats.timings?.totalMs ?? 0,
							expectedStarCount: stats.expectedStarCount,
							actualStarCount: stats.actualStarCount,
							nodeCount: stats.nodeCount,
							committedNodeCount: stats.committedNodeCount,
							expectedCacheHit: stats.expectedCacheHit,
							skippedCommitWait: stats.skippedCommitWait,
						});
						const targetElapsedMs = options.paceFrames === true
							? (frameIndex * 1000) / fps
							: 0;
						const waitMs = targetElapsedMs > 0
							? Math.max(0, startedAt + targetElapsedMs - performance.now())
							: 0;
						await new Promise((resolve) => window.setTimeout(resolve, waitMs));
					}
				} finally {
					if (recorder.state !== 'inactive') {
						recorder.stop();
					}
				}
				await stopped;
				stream.getTracks().forEach((entry) => entry.stop());

				const blob = new Blob(chunks, {
					type: recorder.mimeType || mimeType || 'video/webm',
				});
				const readStartedAt = performance.now();
				const dataUrl = await blobToDataUrl(blob);
				return {
					width: canvas.width,
					height: canvas.height,
					frameCount,
					fps,
					source: useComposite ? 'composite' : 'canvas',
					layoutId: layout.id,
					mimeType: blob.type,
					size: blob.size,
					recordMs: performance.now() - startedAt,
					readMs: performance.now() - readStartedAt,
					timings,
					dataUrl,
				};
			}

			async function initialize() {
				if (!mount) {
					throw new Error('Missing radio bubble video mount element.');
				}

				mounted = await mountRadioBubbleViewer(mount, {
					pixelRatio: 1,
					observeResize: false,
					autoStart: false,
					enableSelectionRefreshController: false,
					onStarFieldCommit,
					preserveDrawingBuffer,
				});
				enterManualTimeline();
				applyCamera(0);
				updateOverlay(0);
				renderTimelineStep(0);
				const initialStats = await settleStars({
					frameIndex: 0,
					sceneTimeSecs: 0,
					timeoutMs: INITIAL_TIMEOUT_MS,
				});
				if (initialStats.actualStarCount <= 0) {
					throw new Error('Initial radio bubble export readiness produced empty star geometry.');
				}
				console.info('[radio-bubble-video] full ready', initialStats);
				exportApi.readyState = 'ready';
				return initialStats;
			}

			exportApi.ready = initialize().catch((error) => {
				exportApi.readyState = 'error';
				exportApi.error = error instanceof Error ? error.message : String(error);
				console.error('[radio-bubble-video]', error);
				throw error;
			});
		</script>
	</body>
</html>

