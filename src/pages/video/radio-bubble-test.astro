---
const title = 'Radio Bubble Video Export Test';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
	</head>
	<body>
		<main class="video-stage" aria-label={title}>
			<div class="skyview" data-video-skyview></div>
			<div class="copy-overlay" data-video-overlay>
				<p class="copy-overlay__eyebrow" data-video-overlay-eyebrow></p>
				<p class="copy-overlay__title" data-video-overlay-title></p>
				<p class="copy-overlay__body" data-video-overlay-body></p>
			</div>
		</main>

		<script>
			import { mountRadioBubbleViewer } from '../../scripts/radio-bubble-viewer.js';

			const FRAME_TIMEOUT_MS = 45_000;
			const SOLAR_ORIGIN_PC = Object.freeze({ x: 0, y: 0, z: 0 });
			const OUTSIDE_OBSERVER_PC = Object.freeze({ x: 0, y: 0, z: 175 });
			const CUES = Object.freeze([
				{
					startSecs: 0,
					endSecs: 2.25,
					eyebrow: 'Radio bubble',
					title: 'A century of signals forms a small shell.',
					body: 'The blue sphere marks the wavefront from Earth. After 131 years, it reaches only about 40 parsecs from the Sun.',
				},
				{
					startSecs: 2.25,
					endSecs: 4.5,
					eyebrow: 'Local stars',
					title: 'Nearby systems sit inside the bubble.',
					body: 'Most of the stars touched by our broadcasts are faint red and orange dwarfs, invisible to unaided eyes on Earth.',
				},
				{
					startSecs: 4.5,
					endSecs: 6,
					eyebrow: 'Galactic scale',
					title: 'Against the Milky Way, this is almost nothing.',
					body: 'The radio bubble is tiny beside the galaxy, and the signals are already extraordinarily weak.',
				},
			]);

			const mount = document.querySelector('[data-video-skyview]');
			const overlay = document.querySelector('[data-video-overlay]');
			const overlayEyebrow = document.querySelector('[data-video-overlay-eyebrow]');
			const overlayTitle = document.querySelector('[data-video-overlay-title]');
			const overlayBody = document.querySelector('[data-video-overlay-body]');

			let mounted = null;
			let manualTimeMs = 0;

			const starReadiness = {
				commitCount: 0,
				lastCommit: null,
				lastSignature: null,
				pendingSignature: null,
				waiters: new Set(),
			};

			const exportApi = {
				ready: null,
				readyState: 'loading',
				error: null,
				getStatus,
				startClip,
				captureFrame,
			};
			window.__radioBubbleVideoExport = exportApi;

			function getStarStats() {
				const stats = mounted?.starLayer?.getStats?.() ?? {};
				return {
					nodeCount: Number(stats.nodeCount ?? 0),
					starCount: Number(stats.starCount ?? 0),
					loadGeneration: Number(stats.loadGeneration ?? 0),
				};
			}

			function notifyCommitWaiters() {
				for (const waiter of starReadiness.waiters) {
					waiter();
				}
			}

			function onStarFieldCommit(commit) {
				const stats = commit?.stats ?? {};
				starReadiness.commitCount += 1;
				starReadiness.lastCommit = {
					starCount: Number(commit?.starCount ?? stats.starCount ?? 0),
					nodeCount: Number(commit?.nodeCount ?? stats.nodeCount ?? 0),
					loadGeneration: Number(commit?.loadGeneration ?? stats.loadGeneration ?? 0),
					timeMs: performance.now(),
				};
				starReadiness.lastSignature = starReadiness.pendingSignature ?? starReadiness.lastSignature;
				notifyCommitWaiters();
			}

			function selectionSignature(selection) {
				const nodes = Array.isArray(selection?.nodes) ? selection.nodes : [];
				return nodes
					.map((node) => node?.nodeKey ?? `${node?.payloadOffset ?? 'none'}:${node?.payloadLength ?? 0}`)
					.join('|');
			}

			function getPayloadNodes(selection) {
				return (Array.isArray(selection?.nodes) ? selection.nodes : [])
					.filter((node) => node && node.payloadLength > 0);
			}

			async function computeExpectedStarCount(nodes) {
				if (!Array.isArray(nodes) || nodes.length === 0) {
					return 0;
				}

				const renderService = mounted.datasetSession.getRenderService();
				const entries = await renderService.fetchNodePayloadBatch(nodes);
				let expectedStarCount = 0;
				for (const entry of entries) {
					const decoded = renderService.decodePayload(entry.buffer, entry.node);
					expectedStarCount += Number(decoded?.count ?? 0);
				}
				return expectedStarCount;
			}

			function currentCommitMatches(signature, expectedStarCount) {
				const stats = getStarStats();
				if (stats.starCount !== expectedStarCount) {
					return false;
				}
				if (starReadiness.lastSignature === signature) {
					return true;
				}
				if (starReadiness.lastSignature == null && starReadiness.pendingSignature === signature) {
					starReadiness.lastSignature = signature;
					return true;
				}
				return false;
			}

			function createReadinessError(details) {
				const stats = getStarStats();
				const sceneTime = Number.isFinite(details.sceneTimeSecs)
					? details.sceneTimeSecs.toFixed(3)
					: 'unknown';
				return new Error(
					`Radio bubble frame readiness timeout: frame=${details.frameIndex} expected=${details.expectedStarCount} actual=${stats.starCount} nodeCount=${details.nodeCount} committedNodeCount=${stats.nodeCount} sceneTime=${sceneTime}s`,
				);
			}

			function waitForCommittedStars(details) {
				const {
					signature,
					expectedStarCount,
					timeoutMs = FRAME_TIMEOUT_MS,
				} = details;

				if (currentCommitMatches(signature, expectedStarCount)) {
					return Promise.resolve(getStarStats());
				}

				return new Promise((resolve, reject) => {
					let done = false;
					let timeoutId = null;

					function finish(callback, value) {
						if (done) return;
						done = true;
						clearTimeout(timeoutId);
						starReadiness.waiters.delete(check);
						callback(value);
					}

					function check() {
						if (currentCommitMatches(signature, expectedStarCount)) {
							finish(resolve, getStarStats());
						}
					}

					timeoutId = window.setTimeout(() => {
						finish(reject, createReadinessError(details));
					}, timeoutMs);
					starReadiness.waiters.add(check);
					check();
				});
			}

			function updateOverlay(sceneTimeSecs) {
				const cue = CUES.find((entry) => sceneTimeSecs >= entry.startSecs && sceneTimeSecs < entry.endSecs)
					?? CUES[CUES.length - 1];
				const localTime = sceneTimeSecs - cue.startSecs;
				const fadeIn = Math.min(1, Math.max(0, localTime / 0.35));
				const fadeOut = Math.min(1, Math.max(0, (cue.endSecs - sceneTimeSecs) / 0.35));
				const opacity = Math.min(fadeIn, fadeOut);

				if (overlayEyebrow) overlayEyebrow.textContent = cue.eyebrow;
				if (overlayTitle) overlayTitle.textContent = cue.title;
				if (overlayBody) overlayBody.textContent = cue.body;
				if (overlay) overlay.style.opacity = String(opacity);
			}

			function setOutsideCamera() {
				const { viewer, cameraController } = mounted;
				cameraController.cancelAutomation();
				cameraController.rig.setPosition(OUTSIDE_OBSERVER_PC);
				cameraController.rig.orientToward(SOLAR_ORIGIN_PC);
				viewer.setState({
					observerPc: { ...OUTSIDE_OBSERVER_PC },
					targetPc: { ...SOLAR_ORIGIN_PC },
				});
				cameraController.lockAt(SOLAR_ORIGIN_PC, {
					dwellMs: 0,
					recenterSpeed: 0.22,
				});
				cameraController.orbit(SOLAR_ORIGIN_PC, {
					radius: 175,
					angularSpeed: 0.045,
				});
			}

			function enterManualTimeline() {
				const runtime = mounted.viewer.runtime;
				mounted.viewer.stop();
				runtime.running = true;
				runtime.previousFrameTimeMs = null;
				runtime.startedAtTimeMs = 0;
				runtime.frameNumber = 0;
				manualTimeMs = 0;
			}

			function renderTimelineStep(deltaSecs = 0) {
				const runtime = mounted.viewer.runtime;
				manualTimeMs += Math.max(0, Number(deltaSecs) || 0) * 1000;
				runtime.frame(manualTimeMs);
			}

			async function settleStars({ frameIndex, sceneTimeSecs, timeoutMs = FRAME_TIMEOUT_MS }) {
				const selection = await mounted.viewer.refreshSelection();
				const payloadNodes = getPayloadNodes(selection);
				const signature = selectionSignature(selection);
				const expectedStarCount = await computeExpectedStarCount(payloadNodes);
				starReadiness.pendingSignature = signature;
				renderTimelineStep(0);
				const stats = await waitForCommittedStars({
					frameIndex,
					sceneTimeSecs,
					signature,
					expectedStarCount,
					nodeCount: payloadNodes.length,
					timeoutMs,
				});
				mounted.viewer.runtime.renderOnce();
				return {
					frameIndex,
					sceneTimeSecs,
					expectedStarCount,
					actualStarCount: stats.starCount,
					nodeCount: payloadNodes.length,
					committedNodeCount: stats.nodeCount,
					loadGeneration: stats.loadGeneration,
					selectionMeta: selection.meta ?? {},
				};
			}

			function getStatus() {
				return {
					readyState: exportApi.readyState,
					error: exportApi.error,
					starStats: getStarStats(),
					commitCount: starReadiness.commitCount,
					lastCommit: starReadiness.lastCommit,
				};
			}

			async function startClip() {
				await exportApi.ready;
				setOutsideCamera();
				enterManualTimeline();
				updateOverlay(0);
				renderTimelineStep(0);
				return settleStars({
					frameIndex: 0,
					sceneTimeSecs: 0,
					timeoutMs: 90_000,
				});
			}

			async function captureFrame({ frameIndex, timeSecs, deltaSecs }) {
				await exportApi.ready;
				updateOverlay(Number(timeSecs) || 0);
				renderTimelineStep(deltaSecs);
				return settleStars({
					frameIndex,
					sceneTimeSecs: Number(timeSecs) || 0,
				});
			}

			async function initialize() {
				if (!mount) {
					throw new Error('Missing radio bubble video mount element.');
				}

				mounted = await mountRadioBubbleViewer(mount, {
					pixelRatio: 1,
					observeResize: false,
					autoStart: false,
					enableSelectionRefreshController: false,
					onStarFieldCommit,
				});
				setOutsideCamera();
				enterManualTimeline();
				updateOverlay(0);
				renderTimelineStep(0);
				const initialStats = await settleStars({
					frameIndex: 0,
					sceneTimeSecs: 0,
					timeoutMs: 90_000,
				});
				if (initialStats.actualStarCount <= 0) {
					throw new Error('Initial radio bubble export readiness produced empty star geometry.');
				}
				console.info('[radio-bubble-video] ready', initialStats);
				exportApi.readyState = 'ready';
				return initialStats;
			}

			exportApi.ready = initialize().catch((error) => {
				exportApi.readyState = 'error';
				exportApi.error = error instanceof Error ? error.message : String(error);
				console.error('[radio-bubble-video]', error);
				throw error;
			});
		</script>
	</body>
</html>

<style is:global>
	html,
	body {
		width: 100%;
		height: 100%;
		margin: 0;
		background: #02040b;
		overflow: hidden;
	}

	body {
		font-family:
			Inter,
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			sans-serif;
	}

	.video-stage {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #02040b;
	}

	.skyview {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		background: #02040b;
	}

	.skyview canvas {
		width: 100% !important;
		height: 100% !important;
		display: block;
	}

	.copy-overlay {
		position: absolute;
		left: 144px;
		bottom: 132px;
		z-index: 2;
		max-width: 1360px;
		color: #f7fbff;
		text-shadow: 0 6px 30px rgba(0, 0, 0, 0.72);
		opacity: 0;
		pointer-events: none;
	}

	.copy-overlay__eyebrow,
	.copy-overlay__title,
	.copy-overlay__body {
		margin: 0;
		letter-spacing: 0;
	}

	.copy-overlay__eyebrow {
		margin-bottom: 22px;
		color: #8fd5ff;
		font-size: 28px;
		line-height: 1.1;
		font-weight: 700;
		text-transform: uppercase;
	}

	.copy-overlay__title {
		max-width: 21ch;
		font-size: 76px;
		line-height: 1.02;
		font-weight: 750;
	}

	.copy-overlay__body {
		max-width: 46ch;
		margin-top: 32px;
		color: rgba(236, 244, 255, 0.88);
		font-size: 38px;
		line-height: 1.35;
		font-weight: 450;
	}
</style>
