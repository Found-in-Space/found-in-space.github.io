---
import MadeByKaj from '../../components/MadeByKaj.astro';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const basePath = import.meta.env.BASE_URL;
const parallaxPath = `${basePath}explore/parallax/`;
---

<Layout
	title="Constellations and 3D Space | Found in Space"
	description="Fly through Orion to see how a familiar constellation changes when the stars are placed in three dimensions."
>
	<SiteHeader section="Explore" />

	<main class="page">
		<section class="intro">
			<p class="eyebrow">Explore</p>
			<h1>Constellations and 3D Space</h1>
			<p class="lede">
				Orion is one of the most recognised shapes in the sky. Fly through the local stars and
				watch how quickly the familiar pattern breaks apart once the stars are placed at their
				real distances.
			</p>
		</section>

		<section class="viewer-section" id="viewer">
			<div class="viewer-shell" data-constellation-viewer="freeFly"></div>
			<p class="status">Status: <span data-viewer-status>Loading the Orion fly-through…</span></p>
		</section>

		<section class="notes">
			<article class="panel">
				<p class="panel__eyebrow">Try this</p>
				<h3>Move sideways, not only forward</h3>
				<p>
					Sideways motion is where the constellation starts to give itself away. The stars do not
					all slide together because they are not all the same distance from Earth.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Notice</p>
				<h3>A picture in the sky is not a structure in space</h3>
				<p>
					Constellations are patterns on our sky, not tight physical groups. They can still be
					useful guides, but they are the beginning of the story, not the end.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Try also</p>
				<h3>Isolate the effect with the parallax demo</h3>
				<p>
					The parallax demo keeps Orion fixed and changes only the observing position, letting
					you focus on the geometric shift before exploring at larger scale.
				</p>
				<p class="notes__link">
					<a href={parallaxPath}>Open the parallax demo</a>
				</p>
			</article>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<script>
	import { mountConstellationViewer } from '../../scripts/examples/constellation-viewer.js';

	const mount = document.querySelector('[data-constellation-viewer]');
	const statusEl = document.querySelector('[data-viewer-status]');

	if (mount) {
		mountConstellationViewer(mount, {
			mode: 'freeFly',
			onStatus: (msg) => {
				if (statusEl) statusEl.textContent = msg;
			},
		}).catch((err) => {
			console.error('[website:constellation-mount]', err);
			if (statusEl) statusEl.textContent = err instanceof Error ? err.message : String(err);
		});
	}
</script>

<style>
	.intro {
		padding: 2rem 0 1.75rem;
	}

	h1,
	h3 {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		max-width: 12ch;
	}

	h3 {
		font-size: 1.35rem;
		line-height: 1.1;
		margin-bottom: 0.7rem;
	}

	p {
		margin: 0;
		line-height: 1.7;
		color: var(--fis-text-soft);
	}

	p + p {
		margin-top: 0.95rem;
	}

	/* ── Viewer ──────────────────────────────────── */

	.viewer-section {
		margin-left: -1.5rem;
		margin-right: -1.5rem;
	}

	.viewer-shell {
		width: 100%;
		height: clamp(28rem, 72vh, 54rem);
		background:
			radial-gradient(circle at top, rgba(148, 220, 255, 0.08), transparent 20%),
			#02040b;
		touch-action: none;
		cursor: grab;
	}

	.viewer-shell:active {
		cursor: grabbing;
	}

	.status {
		padding: 0.75rem 1.5rem;
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.status span {
		color: var(--fis-blue);
	}

	/* ── Notes ───────────────────────────────────── */

	.notes {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.notes__link a {
		color: var(--fis-gold);
		text-decoration-color: var(--fis-gold-subtle);
	}

	/* ── Responsive ──────────────────────────────── */

	@media (max-width: 800px) {
		.notes {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			padding-top: 2.2rem;
		}

		h1 {
			font-size: clamp(2.4rem, 13vw, 4rem);
		}
	}
</style>
