---
import MadeByKaj from '../../components/MadeByKaj.astro';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const basePath = import.meta.env.BASE_URL;
const parallaxPath = `${basePath}explore/parallax/`;
---

<Layout
	title="Constellations and 3D Space | Found in Space"
	description="Fly through Orion to see how a familiar constellation changes when the stars are placed in three dimensions."
>
	<SiteHeader section="Explore" />

	<main class="page">
		<section class="intro">
			<p class="eyebrow">Explore</p>
			<h1>Constellations and 3D Space</h1>
			<p class="lede">
				Orion is one of the most recognised shapes in the sky. Fly through the local stars and
				watch how quickly the familiar pattern breaks apart once the stars are placed at their
				real distances.
			</p>
		</section>

		<section class="viewer-section" id="viewer">
			<div class="viewer-controls">
				<label class="viewer-controls__label" for="freefly-constellation-select">Look toward</label>
				<select
					id="freefly-constellation-select"
					class="viewer-controls__select"
					data-freefly-constellation
					disabled
				>
					<option value="">Loading constellations…</option>
				</select>
			</div>
			<div class="viewer-stage">
				<div class="viewer-shell" data-constellation-viewer="freeFly"></div>
				<aside class="star-pick-card panel" data-star-pick-card hidden>
					<button
						type="button"
						class="star-pick-card__close"
						data-star-pick-dismiss
						aria-label="Close star details"
					>
						×
					</button>
					<p class="star-pick-card__line">
						<span class="star-pick-card__label">Name</span>
						<span data-star-pick-proper>—</span>
					</p>
					<p class="star-pick-card__line">
						<span class="star-pick-card__label">Bayer</span>
						<span data-star-pick-bayer>—</span>
					</p>
					<p class="star-pick-card__line">
						<span class="star-pick-card__label">Catalog</span>
						<span class="star-pick-card__catalog-value" data-star-pick-catalog-value>—</span>
					</p>
					<p class="star-pick-card__line">
						<span class="star-pick-card__label">Distance</span>
						<span class="star-pick-card__catalog-value" data-star-pick-distance>—</span>
					</p>
					<div class="star-pick-card__actions">
						<button
							type="button"
							class="star-pick-card__icon-btn"
							data-star-pick-fly-orbit
							aria-label="Fly to this star and orbit"
							title="Fly to this star and orbit"
						>
							<span class="star-pick-card__icon-btn-char" aria-hidden="true">→</span>
						</button>
						<button
							type="button"
							class="star-pick-card__icon-btn"
							data-star-pick-simbad
							hidden
							aria-label="Open this object in SIMBAD"
							title="Open in SIMBAD"
						>
							<svg
								class="star-pick-card__icon-svg"
								xmlns="http://www.w3.org/2000/svg"
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<circle cx="11" cy="11" r="8"></circle>
								<path d="m21 21-4.3-4.3"></path>
							</svg>
						</button>
					</div>
				</aside>
			</div>
			<p class="status">Status: <span data-viewer-status>Loading the Orion fly-through…</span></p>
		</section>

		<section class="notes">
			<article class="panel">
				<p class="panel__eyebrow">Try this</p>
				<h3>Move sideways, not only forward</h3>
				<p>
					Sideways motion is where the constellation starts to give itself away. The stars do not
					all slide together because they are not all the same distance from Earth.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Notice</p>
				<h3>A picture in the sky is not a structure in space</h3>
				<p>
					Constellations are patterns on our sky, not tight physical groups. They can still be
					useful guides, but they are the beginning of the story, not the end.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Try also</p>
				<h3>Isolate the effect with the parallax demo</h3>
				<p>
					The parallax demo keeps Orion fixed and changes only the observing position, letting
					you focus on the geometric shift before exploring at larger scale.
				</p>
				<p class="notes__link">
					<a href={parallaxPath}>Open the parallax demo</a>
				</p>
			</article>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<script>
	import { mountConstellationViewer } from '../../scripts/examples/constellation-viewer.js';

	const mount = document.querySelector('[data-constellation-viewer]');
	const statusEl = document.querySelector('[data-viewer-status]');
	const constellationSelect = document.querySelector('[data-freefly-constellation]');
	const starPickCard = document.querySelector('[data-star-pick-card]');

	if (mount) {
		mountConstellationViewer(mount, {
			mode: 'freeFly',
			onStatus: (msg) => {
				if (statusEl) statusEl.textContent = msg;
			},
			...(starPickCard instanceof HTMLElement ? { starPickCard } : {}),
		})
			.then(({ viewer, constellations = [], setConstellation } = {}) => {
				if (!(constellationSelect instanceof HTMLSelectElement)) return;

				const canvas = viewer?.canvas;
				if (canvas instanceof HTMLCanvasElement) {
					canvas.tabIndex = -1;
				}

				constellationSelect.innerHTML = '';
				for (const { iau, label } of constellations) {
					const option = document.createElement('option');
					option.value = iau;
					option.textContent = label;
					constellationSelect.append(option);
				}

				const defaultIau = constellations.some((entry) => entry.iau === 'Ori')
					? 'Ori'
					: constellations[0]?.iau;

				// Initial aim uses ORION_CENTER_PC; skip lookAt here so the view does not tween on load.
				if (defaultIau) {
					constellationSelect.value = defaultIau;
				}

				constellationSelect.disabled = constellations.length === 0;
				constellationSelect.addEventListener('change', () => {
					setConstellation?.(constellationSelect.value);
					constellationSelect.blur();
					if (canvas instanceof HTMLCanvasElement) {
						canvas.focus({ preventScroll: true });
					}
				});
			})
			.catch((err) => {
				console.error('[website:constellation-mount]', err);
				if (statusEl) statusEl.textContent = err instanceof Error ? err.message : String(err);
				if (constellationSelect instanceof HTMLSelectElement) {
					constellationSelect.disabled = true;
					constellationSelect.innerHTML = '<option value="">Unable to load constellations</option>';
				}
			});
	}
</script>

<style>
	.intro {
		padding: 2rem 0 1.75rem;
	}

	h1,
	h3 {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		max-width: 12ch;
	}

	h3 {
		font-size: 1.35rem;
		line-height: 1.1;
		margin-bottom: 0.7rem;
	}

	p {
		margin: 0;
		line-height: 1.7;
		color: var(--fis-text-soft);
	}

	p + p {
		margin-top: 0.95rem;
	}

	/* ── Viewer ──────────────────────────────────── */

	.viewer-section {
		margin-left: -1.5rem;
		margin-right: -1.5rem;
	}

	.viewer-stage {
		position: relative;
		width: 100%;
	}

	.star-pick-card {
		position: absolute;
		left: 0.75rem;
		bottom: 0.75rem;
		/* Above SkyKit HUD (createHud uses z-index: 100). */
		z-index: 110;
		max-width: min(22rem, calc(100% - 1.5rem));
		padding: 0.85rem 2.25rem 0.85rem 1rem;
		margin: 0;
		font-family: var(--fis-font-ui);
		font-size: 0.88rem;
		line-height: 1.45;
		color: var(--fis-text-soft);
		box-shadow: var(--fis-shadow);
	}

	.star-pick-card__close {
		position: absolute;
		top: 0.35rem;
		right: 0.35rem;
		width: 1.75rem;
		height: 1.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: none;
		border-radius: 50%;
		background: transparent;
		color: var(--fis-text-muted);
		font-size: 1.35rem;
		line-height: 1;
		cursor: pointer;
	}

	.star-pick-card__close:hover,
	.star-pick-card__close:focus-visible {
		color: var(--fis-gold);
		outline: none;
	}

	.star-pick-card__close:focus-visible {
		box-shadow: 0 0 0 2px var(--fis-gold-subtle);
	}

	.star-pick-card__line {
		margin: 0;
		word-break: break-word;
	}

	.star-pick-card__line + .star-pick-card__line {
		margin-top: 0.35rem;
	}

	.star-pick-card__label {
		display: inline-block;
		min-width: 4.5rem;
		font-size: 0.72rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--fis-text-muted);
		vertical-align: top;
	}

	.star-pick-card__catalog-value {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.82rem;
		color: var(--fis-text);
	}

	.star-pick-card__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-start;
		gap: 0.35rem;
		margin-top: 0.6rem;
		padding-top: 0.55rem;
		border-top: 1px solid var(--fis-line);
		pointer-events: auto;
	}

	.star-pick-card__icon-btn {
		box-sizing: border-box;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.65rem;
		height: 1.65rem;
		padding: 0;
		margin: 0;
		border: 1px solid var(--fis-line-strong);
		border-radius: 0.4rem;
		background: rgba(8, 16, 32, 0.55);
		color: var(--fis-text-soft);
		font: inherit;
		line-height: 1;
		cursor: pointer;
		transition:
			border-color 0.12s ease,
			background 0.12s ease,
			color 0.12s ease;
	}

	.star-pick-card__icon-btn:hover,
	.star-pick-card__icon-btn:focus-visible {
		border-color: var(--fis-gold-subtle);
		color: var(--fis-gold);
		background: rgba(20, 40, 70, 0.55);
		outline: none;
	}

	.star-pick-card__icon-btn:focus-visible {
		box-shadow: 0 0 0 2px var(--fis-gold-subtle);
	}

	.star-pick-card__icon-btn-char {
		font-size: 0.78rem;
		font-weight: 600;
		transform: translateY(-0.04em);
	}

	.star-pick-card__icon-svg {
		display: block;
		flex-shrink: 0;
	}

	.viewer-controls {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.8rem 1.5rem 0.65rem;
		background: rgba(2, 4, 11, 0.92);
		border-top: 1px solid var(--fis-line);
		border-bottom: 1px solid var(--fis-line);
	}

	.viewer-controls__label {
		font-family: var(--fis-font-ui);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fis-text-muted);
	}

	.viewer-controls__select {
		min-width: min(26rem, 100%);
		max-width: 100%;
		background-color: var(--fis-panel);
		color: var(--fis-text);
		border: 1px solid var(--fis-line-strong);
		border-radius: 0.6rem;
		padding: 0.38rem 0.62rem;
		font-family: var(--fis-font-ui);
		font-size: 0.92rem;
	}

	.viewer-controls__select:focus-visible {
		outline: 2px solid var(--fis-gold);
		outline-offset: 1px;
	}

	.viewer-controls__select:disabled {
		opacity: 0.65;
		cursor: not-allowed;
	}

	.viewer-shell {
		width: 100%;
		height: clamp(28rem, 72vh, 54rem);
		background:
			radial-gradient(circle at top, rgba(148, 220, 255, 0.08), transparent 20%),
			#02040b;
		touch-action: none;
		cursor: grab;
	}

	.viewer-shell:active {
		cursor: grabbing;
	}

	/* Programmatic focus after constellation select; skykit appends canvas client-side — :global so scoped Astro CSS matches it. */
	.viewer-shell :global(canvas:is(:focus, :focus-visible)) {
		outline: none;
		box-shadow: none;
	}

	.status {
		padding: 0.75rem 1.5rem;
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.status span {
		color: var(--fis-blue);
	}

	/* ── Notes ───────────────────────────────────── */

	.notes {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.notes__link a {
		color: var(--fis-gold);
		text-decoration-color: var(--fis-gold-subtle);
	}

	/* ── Responsive ──────────────────────────────── */

	@media (max-width: 800px) {
		.notes {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			padding-top: 2.2rem;
		}

		.viewer-controls {
			flex-direction: column;
			align-items: flex-start;
			padding-left: 1rem;
			padding-right: 1rem;
		}

		.viewer-controls__select {
			width: 100%;
		}

		h1 {
			font-size: clamp(2.4rem, 13vw, 4rem);
		}
	}
</style>
