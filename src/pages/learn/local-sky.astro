---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import MadeByKaj from '../../components/MadeByKaj.astro';

const basePath = import.meta.env.BASE_URL;

const topics = [
	{
		slug: 'sky-is-3d',
		title: 'The sky is 3D',
		summary:
			'Constellations look flat from Earth, but the stars that make them are spread through space at very different distances.',
	},
	{
		slug: 'what-is-nearby-in-space',
		title: 'What is nearby in space?',
		summary:
			'A tour of the Solar System, the nearest stars, and the idea of a local stellar neighbourhood.',
	},
	{
		slug: 'how-far-is-a-light-year',
		title: 'How far is a light-year?',
		summary:
			'A light-year is a useful human-scale way to think about the distances between stars.',
	},
	{
		slug: 'what-is-a-parsec',
		title: 'What is a parsec?',
		summary:
			'The parsec comes directly from parallax and is the natural distance unit for nearby stars.',
	},
	{
		slug: 'how-we-measure-stellar-distance',
		title: 'How we measure stellar distance',
		summary:
			'Nearby stellar distances can be measured geometrically by watching stars shift against the background as Earth moves around the Sun.',
	},
	{
		slug: 'what-gaia-measures',
		title: 'What Gaia measures',
		summary:
			'Gaia measures position, parallax, motion, and brightness for an enormous number of stars, giving us an unprecedented 3D map of the sky.',
	},
	{
		slug: 'apparent-vs-absolute-magnitude',
		title: 'Apparent magnitude and absolute magnitude',
		summary:
			'A star can look bright because it is nearby, or because it is intrinsically luminous. Magnitude helps separate those ideas.',
	},
	{
		slug: 'why-stars-have-different-colours',
		title: 'Why stars have different colours',
		summary:
			'Stellar colour is closely linked to temperature, and helps us understand what kind of star we are looking at.',
	},
	{
		slug: 'main-sequence',
		title: 'The main sequence',
		summary:
			'Most stars spend most of their lives on the main sequence, where mass, temperature, colour, and brightness are closely related.',
	},
	{
		slug: 'red-dwarfs-quiet-majority',
		title: 'Red dwarfs: the Galaxy’s quiet majority',
		summary:
			'Red dwarfs are small, cool, faint, and incredibly common. They dominate the stellar population of the Milky Way.',
	},
	{
		slug: 'white-dwarfs-dead-stars-still-glowing',
		title: 'White dwarfs: dead stars still glowing',
		summary:
			'White dwarfs are the dense cooling remnants of ordinary stars and form a distinct faint branch in stellar-population plots.',
	},
	{
		slug: 'brown-dwarfs-and-ultracool-objects',
		title: 'Brown dwarfs and ultracool objects',
		summary:
			'Brown dwarfs are too small to sustain ordinary hydrogen fusion. They are faint, cool, and hard for optical surveys like Gaia to detect at larger distances.',
	},
	{
		slug: 'hr-diagram',
		title: 'The Hertzsprung-Russell diagram',
		summary:
			'The HR diagram is one of astronomy’s most powerful maps, revealing how stars are grouped by temperature, brightness, and stage of life.',
	},
	{
		slug: 'open-clusters-and-moving-groups',
		title: 'Open clusters and moving groups',
		summary:
			'Some stars share common origins and motions, allowing Gaia to reveal loose families and dissolved clusters across the sky.',
	},
];
---

<Layout
	title="From the Night Sky to the Solar Neighbourhood | Learn | Found in Space"
	description="A guided journey from familiar constellations into the three-dimensional reality of the stars near the Sun."
>
	<SiteHeader section="Learn" />

	<main class="page">
		<header class="journey-hero">
			<div class="journey-hero__content">
				<p class="eyebrow">Guided Journey</p>
				<h1>From the night sky to the solar neighbourhood</h1>
				<p class="lede">
					We often see the stars as a flat backdrop of light. This journey turns that picture
					inside out, moving from the constellations you recognise into the real 3D volume of the
					local galaxy.
				</p>
				<div class="journey-meta">
					<span class="meta-item">
						<strong>Level:</strong> Intro
					</span>
					<span class="meta-item">
						<strong>Path:</strong> 14 topics
					</span>
					<span class="meta-item">
						<strong>Key Question:</strong> How do we know where the stars actually are?
					</span>
				</div>
				<a href={`${basePath}learn/${topics[0].slug}/`} class="button button--primary"
					>Start with topic 1: {topics[0].title}</a
				>
			</div>
		</header>

		<section class="topic-list">
			<h2 class="section-title">Journey Map</h2>
			<div class="topic-grid">
				{
					topics.map((topic, index) => (
						<article class="topic-card">
							<span class="topic-number">{String(index + 1).padStart(2, '0')}</span>
							<div class="topic-card__content">
								<h3>{topic.title}</h3>
								<p>{topic.summary}</p>
								<a href={`${basePath}learn/${topic.slug}/`} class="topic-card__link">
									Read topic
								</a>
							</div>
						</article>
					))
				}
			</div>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<style>
	.journey-hero {
		padding: 4rem 0;
		border-bottom: 1px solid var(--fis-line);
		margin-bottom: 4rem;
	}

	.journey-hero__content {
		max-width: 48rem;
	}

	h1 {
		font-size: clamp(2.4rem, 6vw, 4.2rem);
		line-height: 1.05;
		margin: 0 0 1.5rem;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	.lede {
		margin-bottom: 2rem;
	}

	.journey-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		margin-bottom: 2.5rem;
		padding: 1.25rem 0;
		border-top: 1px solid rgba(141, 183, 255, 0.1);
		border-bottom: 1px solid rgba(141, 183, 255, 0.1);
		font-size: 0.94rem;
		color: var(--fis-text-muted);
	}

	.meta-item strong {
		color: var(--fis-gold);
		margin-right: 0.35rem;
	}

	.section-title {
		font-size: 2rem;
		margin-bottom: 2.5rem;
		letter-spacing: -0.02em;
	}

	.topic-grid {
		display: grid;
		gap: 1.25rem;
	}

	.topic-card {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 2rem;
		padding: 2rem;
		background: var(--fis-panel);
		border: 1px solid var(--fis-line);
		border-radius: var(--fis-radius);
		backdrop-filter: blur(10px);
		box-shadow: var(--fis-shadow);
		transition:
			border-color 160ms ease,
			transform 160ms ease;
	}

	.topic-card:hover {
		border-color: rgba(242, 200, 121, 0.3);
		transform: translateX(8px);
	}

	.topic-number {
		font-size: 3rem;
		font-weight: 700;
		line-height: 1;
		color: rgba(242, 200, 121, 0.15);
		font-family: var(--fis-font-ui);
	}

	.topic-card h3 {
		margin: 0 0 0.6rem;
		font-size: 1.45rem;
		font-weight: 600;
		color: var(--fis-text);
	}

	.topic-card p {
		margin: 0 0 1.25rem;
		line-height: 1.65;
		color: var(--fis-text-soft);
		max-width: 42rem;
	}

	.topic-card__link {
		display: inline-flex;
		color: var(--fis-gold);
		font-size: 0.94rem;
		text-decoration-color: rgba(242, 200, 121, 0.35);
	}

	@media (max-width: 720px) {
		.topic-card {
			grid-template-columns: 1fr;
			gap: 1rem;
			padding: 1.5rem;
		}

		.topic-number {
			font-size: 2rem;
		}

		.topic-card:hover {
			transform: none;
		}
	}
</style>
