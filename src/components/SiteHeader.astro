---
interface Props {
	section?: string;
}

const { section = 'Explore the nearby stars' } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="site-header__glass" aria-hidden="true"></div>
	<div class="site-header__inner">
		<div class="site-header__bar">
			<a class="wordmark" href={basePath} aria-label="Found in Space home">
				<img class="wordmark__mark" src={`${basePath}robbie.svg`} alt="" aria-hidden="true" />
				<span class="wordmark__text">
					<span class="wordmark__title">Found in Space</span>
					<span class="wordmark__meta">{section}</span>
				</span>
			</a>
			<button
				type="button"
				class="site-nav-toggle"
				id="site-nav-toggle"
				aria-controls="site-nav-primary"
				aria-expanded="false"
				aria-label="Open menu"
			>
				<span class="site-nav-toggle__bars" aria-hidden="true">
					<span class="site-nav-toggle__bar"></span>
					<span class="site-nav-toggle__bar"></span>
					<span class="site-nav-toggle__bar"></span>
				</span>
			</button>
		</div>
		<div class="site-header__backdrop" aria-hidden="true" hidden></div>
		<nav class="site-nav" id="site-nav-primary" aria-label="Primary">
			<a href={basePath}>Home</a>
			<a href={`${basePath}explore/`}>Explore</a>
			<a href={`${basePath}learn/`}>Learn</a>
			<a href={`${basePath}build/`}>Build</a>
			<a href={`${basePath}about/`}>About</a>
		</nav>
	</div>
</header>

<script>
	const mq = window.matchMedia('(max-width: 720px)');

	function initSiteHeader(header) {
		const toggle = header.querySelector('#site-nav-toggle');
		const nav = header.querySelector('#site-nav-primary');
		const backdrop = header.querySelector('.site-header__backdrop');
		if (!toggle || !nav || !backdrop) return;

		function applyMobileNavState() {
			const mobile = mq.matches;
			if (!mobile) {
				header.classList.remove('site-header--nav-open');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', 'Open menu');
				nav.removeAttribute('inert');
				backdrop.hidden = true;
				document.body.style.overflow = '';
				return;
			}
			const open = header.classList.contains('site-header--nav-open');
			toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
			toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
			if (open) {
				nav.removeAttribute('inert');
				backdrop.hidden = false;
				document.body.style.overflow = 'hidden';
			} else {
				nav.setAttribute('inert', '');
				backdrop.hidden = true;
				document.body.style.overflow = '';
			}
		}

		function setOpen(open) {
			header.classList.toggle('site-header--nav-open', open);
			applyMobileNavState();
		}

		toggle.addEventListener('click', () => {
			if (!mq.matches) return;
			setOpen(!header.classList.contains('site-header--nav-open'));
		});

		backdrop.addEventListener('click', () => setOpen(false));

		nav.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				if (mq.matches) setOpen(false);
			});
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && mq.matches && header.classList.contains('site-header--nav-open')) {
				setOpen(false);
				toggle.focus();
			}
		});

		mq.addEventListener('change', applyMobileNavState);
		applyMobileNavState();
	}

	const header = document.querySelector('.site-header');
	if (header) initSiteHeader(header);
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 4;
		width: 100%;
	}

	/* Full-bleed glass; content stays in .site-header__inner (centred column). */
	.site-header__glass {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		background: linear-gradient(180deg, rgba(7, 17, 31, 0.88), rgba(7, 17, 31, 0));
		backdrop-filter: blur(12px);
	}

	.site-header__inner {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: var(--fis-max-width);
		margin: 0 auto;
		padding: 1rem 1.5rem 0.5rem;
	}

	.site-header__bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-width: 0;
		flex: 1;
	}

	.wordmark {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		padding: 0.65rem 0.85rem;
		border-radius: 999px;
		background: rgba(8, 15, 27, 0.68);
		border: 1px solid var(--fis-line);
		box-shadow: var(--fis-shadow);
		text-decoration: none;
	}

	.wordmark__mark {
		width: 2.25rem;
		height: 2.25rem;
		flex: 0 0 auto;
		object-fit: contain;
	}

	.wordmark__text {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.wordmark__title {
		font-size: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fis-gold);
	}

	.wordmark__meta {
		font-size: 0.78rem;
		color: var(--fis-text-muted);
	}

	.site-nav-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border-radius: 999px;
		border: 1px solid var(--fis-blue-subtle);
		background: rgba(8, 15, 27, 0.62);
		color: var(--fis-text-soft);
		cursor: pointer;
		transition:
			background-color 160ms ease,
			border-color 160ms ease,
			color 160ms ease;
	}

	.site-nav-toggle:hover {
		background: rgba(15, 28, 50, 0.82);
		border-color: var(--fis-gold-subtle);
		color: var(--fis-text);
	}

	.site-nav-toggle:focus-visible {
		outline: 2px solid var(--fis-gold);
		outline-offset: 2px;
	}

	.site-nav-toggle__bars {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 1.15rem;
	}

	.site-nav-toggle__bar {
		display: block;
		height: 2px;
		border-radius: 1px;
		background: currentColor;
		transition: transform 200ms ease, opacity 200ms ease;
		transform-origin: center;
	}

	.site-header--nav-open .site-nav-toggle__bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.site-header--nav-open .site-nav-toggle__bar:nth-child(2) {
		opacity: 0;
	}

	.site-header--nav-open .site-nav-toggle__bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.site-header__backdrop {
		display: none;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		font-size: 0.96rem;
	}

	.site-nav a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.55rem;
		padding: 0.55rem 0.9rem;
		border-radius: 999px;
		background: rgba(8, 15, 27, 0.62);
		border: 1px solid var(--fis-blue-subtle);
		color: var(--fis-text-soft);
		text-decoration: none;
		transition:
			transform 160ms ease,
			background-color 160ms ease,
			border-color 160ms ease,
			color 160ms ease;
	}

	.site-nav a:hover {
		transform: translateY(-1px);
		background: rgba(15, 28, 50, 0.82);
		border-color: rgba(242, 200, 121, 0.32);
		color: var(--fis-text);
	}

	@media (max-width: 720px) {
		.site-header__inner {
			flex-wrap: wrap;
			align-items: center;
		}

		.site-header__bar {
			flex: 1 1 100%;
		}

		.site-nav-toggle {
			display: inline-flex;
		}

		.site-header__backdrop {
			display: block;
			position: fixed;
			inset: 0;
			z-index: 3;
			margin: 0;
			border: none;
			padding: 0;
			background: rgba(4, 9, 20, 0.62);
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
			transition:
				opacity 200ms ease,
				visibility 200ms ease;
		}

		.site-header--nav-open .site-header__backdrop {
			opacity: 1;
			visibility: visible;
			pointer-events: auto;
		}

		.site-nav {
			position: absolute;
			left: 1.5rem;
			right: 1.5rem;
			top: calc(100% - 0.35rem);
			z-index: 4;
			flex-direction: column;
			flex-wrap: nowrap;
			align-items: stretch;
			padding: 0.85rem;
			border-radius: var(--fis-radius);
			background: var(--fis-panel-strong);
			border: 1px solid var(--fis-line);
			box-shadow: var(--fis-shadow);
			opacity: 0;
			visibility: hidden;
			transform: translateY(-0.35rem);
			pointer-events: none;
			transition:
				opacity 200ms ease,
				visibility 200ms ease,
				transform 200ms ease;
		}

		.site-header--nav-open .site-nav {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
			pointer-events: auto;
		}

		.site-nav a {
			justify-content: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-nav-toggle__bar,
		.site-header__backdrop,
		.site-nav {
			transition: none;
		}
	}
</style>
