---
import Layout from '../../../layouts/Layout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import TopicNext from '../../../components/TopicNext.astro';
import MadeByKaj from '../../../components/MadeByKaj.astro';

const basePath = import.meta.env.BASE_URL;

const nextTopics = [
	{ slug: 'star-clusters', title: 'Star clusters: families of stars' },
	{ slug: 'radio-bubble', title: 'The radio bubble' },
	{ slug: 'astrophage', title: 'Astrophage' },
];
---

<Layout
	title="The Hertzsprung-Russell diagram | Learn | Found in Space"
	description="Follow a guided HR diagram lesson built from real Gaia data. Compare all-sky, directional, and nearby views from the Sun to see how stellar populations change."
>
	<SiteHeader section="Learn" />

	<main class="page">
		<section class="intro">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href={`${basePath}learn/`}>Learn</a>
				<span class="breadcrumb__sep" aria-hidden="true">›</span>
				<span>The Hertzsprung-Russell diagram</span>
			</nav>
			<p class="eyebrow">Learn</p>
			<h1>The Hertzsprung-Russell diagram</h1>
			<p class="lede">
				The Hertzsprung-Russell diagram plots two things for every star: how bright it
				truly is, and what colour it is. Colour and surface temperature are the same
				thing — a blue-white star is far hotter than a red one. Put those two numbers
				together and you get a remarkably clear picture of what a star is, and how far
				through its life it has come.
			</p>
		</section>

		<section class="body-section prose">
			<h2>How stars end up where they do</h2>
			<p>
				A star spends most of its life doing one thing: fusing hydrogen into helium
				in its core. That steady nuclear burning produces the energy that holds the
				star up against its own gravity. As long as hydrogen lasts, the star sits in a
				well-defined band on the HR diagram called the <strong>main sequence</strong>.
				Where a star sits on that band depends almost entirely on its mass: massive
				stars burn hotter and far brighter, placing them at the top left; lightweight
				stars burn cool and dim, sitting at the bottom right.
			</p>
			<p>
				Mass also decides how long a star lives. A star ten times more massive than
				the Sun burns through its hydrogen roughly a thousand times faster and may
				leave the main sequence in just a few tens of millions of years. A star like
				the Sun takes about ten billion years. A star half the Sun's mass could keep
				burning for longer than the current age of the universe.
			</p>
			<p>
				When a star exhausts the hydrogen in its core it cannot simply keep burning as
				before. The core contracts and heats up while the outer layers swell outward,
				cooling as they expand. The star brightens dramatically but turns red: it has
				become a <strong>red giant</strong>. On the HR diagram this shift appears as a
				branch of evolved stars rising up from the cooler, brighter side of the
				diagram. The point where stars peel away from the main sequence to begin this
				journey is called the <strong>main-sequence turn-off</strong>, and its
				position acts as a clock: the older the population, the lower down the
				turn-off sits, because only the least massive stars are still burning hydrogen.
			</p>
			<p>
				The axes of the diagram run in a slightly unusual direction. Temperature
				decreases from left to right, so hot blue-white stars are on the left and
				cool red stars are on the right. The vertical axis shows
				<strong>absolute magnitude</strong> — a measure of a star's true, intrinsic
				brightness, defined as how bright the star would look if every star were
				placed at the same standard distance from us. This is different from
				<strong>apparent magnitude</strong>, which is simply how bright a star looks
				from Earth: a nearby faint star can outshine a distant brilliant one just
				because it is closer. Stars get fainter with distance, so to convert an
				apparent magnitude into an absolute one you need to know the distance —
				which is precisely what Gaia measures. Below, we start with a magnitude
				cutoff of 6.5, which is an apparent-magnitude limit: stars bright enough to
				be seen from Earth regardless of how luminous they truly are. As the tour
				moves on, you will see the diagram's structure emerge as we change how we
				look at the stars around us, and then fly out to clusters of very different
				ages.
			</p>
		</section>

		<div class="narrated-tour hr-tour" data-hr-tour>
			<div class="narrated-tour__chapters">
				<section class="narrated-tour__chapter" data-step="all-stars">
					<p class="narrated-tour__chapter-eyebrow">Step 1 · Sun · all-sky view</p>
					<h2 class="narrated-tour__chapter-title">The main sequence and the giant branch appear</h2>
					<p>
						We begin at the Sun. This first view plots every Gaia star brighter than
						roughly the faintest stars a person can pick out with the naked eye under a very
						dark sky, with no restriction on viewing direction.
					</p>
					<p>
						Two landmarks dominate the diagram immediately. The broad diagonal band running
						from hot and bright at the top left down to cool and faint at the bottom right is
						the <strong>main sequence</strong> — every star here is steadily fusing hydrogen
						in its core, just as the Sun is doing right now. The Sun itself sits comfortably
						in the middle: not the biggest, not the smallest, just ordinary.
					</p>
					<p>
						The second feature is the plume rising upward on the cool (right) side: the
						<strong>red giant branch</strong>. These are stars that have run out of core
						hydrogen and have swollen outward into luminous, cooler giants. This diagram
						only shows stars brighter than magnitude 6.5. We use that arbitrary limit so
						the data roughly match the stars we can see in the night sky.
					</p>
				</section>

				<section class="narrated-tour__chapter" data-step="inner-plane">
					<p class="narrated-tour__chapter-eyebrow">Step 2 · View only · inner galactic plane</p>
					<h2 class="narrated-tour__chapter-title">Looking toward Carina changes the data</h2>
					<p>
						Now we look in one direction only. Nothing magical happens to the data: we keep
						the same 6.5-magnitude limit from Step 1, but ignore every star outside the part
						of the sky we are facing. The new HR diagram is just a smaller slice of the
						all-sky one.
					</p>
					<p>
						We aim toward Acrux and the rich Carina direction of the southern Milky Way
						because this direction runs along the crowded galactic disc, where gas, dust,
						young clusters, and active star-forming regions are concentrated. That makes it
						a good first contrast with the all-sky view. The shape remains roughly the same,
						just with fewer stars.
					</p>
				</section>

					<section class="narrated-tour__chapter" data-step="out-of-plane">
					<p class="narrated-tour__chapter-eyebrow">Step 3 · View only · high galactic latitude</p>
					<h2 class="narrated-tour__chapter-title">Away from the disc, the mix gets older</h2>
					<p>
						Now we keep looking in one direction, but swing away from the galactic plane
						toward a quieter high-latitude patch marked by Arcturus. Arcturus is a bright
						nearby orange giant, but the important change here is not the star itself. It is
						the direction we are looking.
					</p>
					<p>
						There are simply fewer young, massive stars far above or below the thin disc where
						star formation is concentrated. The data set now leans toward older, more evolved
						stars. The giant branch remains, but the bright hot end of the main sequence thins
						out. Stellar physics has not changed. We have only changed which small part of
						the sky is allowed to contribute stars. What we see is that when we look out of the
						galactic plane, we see an absence of very massive, very young stars, and instead see
						an ageing population tending towards the red giants.
					</p>
				</section>

				<section class="narrated-tour__chapter" data-step="local-volume">
					<p class="narrated-tour__chapter-eyebrow">Step 4 · Volume mode · local census</p>
					<h2 class="narrated-tour__chapter-title">White dwarfs and red dwarfs fill the diagram</h2>
					<p>
						Now the sampling rule changes completely. We drop the brightness cutoff and instead
						include every star inside a fixed sphere around the Sun — we stop asking which
						stars are bright enough to see and start asking which stars are actually nearby.
					</p>
					<p>
						The spectacular super-bright stars mostly disappear because there simply are none
						that close to us. In their place the lower main sequence fills with huge numbers
						of faint red and orange dwarfs. This is the real local population: the Milky Way
						is dominated by small, cool stars.
					</p>
					<p>
						Look also at the lower left corner. The scattered cluster of hot but very faint
						points are <strong>white dwarfs</strong> — the dense, Earth-sized remnants left
						behind after a Sun-like star exhausts all its fuel and sheds its outer layers.
						They are extremely faint, so a nearby count is the only way to see them
						in any numbers. This local benchmark matters, because the next steps leave the
						Sun and we will start to lose these faint objects as Gaia's reach is no longer
						enough to find them.
					</p>
				</section>

				<section class="narrated-tour__chapter" data-step="away-volume">
					<p class="narrated-tour__chapter-eyebrow">Step 5 · Volume mode · 200 pc from the Sun</p>
					<h2 class="narrated-tour__chapter-title">This nearby data set starts to miss faint stars</h2>
					<p>
						Now we carry that same local bubble 200 parsecs away from the Sun. That is still
						nearby on a galactic scale, and the underlying stellar population should not
						change dramatically.
					</p>
					<p>
						And yet the white-dwarf sequence already starts to weaken. The key point is that
						this is <em>not</em> because white dwarfs suddenly become rare 200 parsecs from the
						Sun. It is because Gaia observed from the Solar System, so faint stars around this
						new position can fall below the telescope limit even when they are really there.
						Many white dwarfs and red dwarfs that would belong in a complete local census are
						simply too dim for Gaia to measure from home.
					</p>
					<p>
						This is the lesson's first major warning label: when a feature changes, ask whether
						the stars changed or the data did.
					</p>
				</section>

				<section class="narrated-tour__chapter" data-step="pleiades">
					<p class="narrated-tour__chapter-eyebrow">Step 6 · Young open cluster · Pleiades</p>
					<h2 class="narrated-tour__chapter-title">A young cluster has a clean, unbroken main sequence</h2>
					<p>
						Next we fly to the Pleiades — the Seven Sisters — one of the easiest star clusters
						to spot in the night sky: a tight knot of blue-white stars visible to the naked
						eye. All its stars formed together from the same cloud of gas about 100 million
						years ago.
					</p>
					<p>
						100 million years sounds long, but for stars it is barely a start. Even the
						most massive Pleiades stars have not yet exhausted their core hydrogen, so almost
						the entire cluster still sits on the main sequence. The bright blue end at the
						top is intact, the giant branch is almost empty, and there is no obvious turn-off
						point. Instead of the messy mixed-age field we saw near the Sun, we get a
						tight, clean sequence that shows how stars of different masses look at the same
						young age.
					</p>
				</section>

				<section class="narrated-tour__chapter" data-step="ngc-752">
					<p class="narrated-tour__chapter-eyebrow">Step 7 · Older open cluster · NGC 752</p>
					<h2 class="narrated-tour__chapter-title">The main-sequence turn-off shifts downward with age</h2>
					<p>
						NGC 752 is almost the opposite of the Pleiades. It is a loose open cluster in
						Andromeda whose stars have had well over a billion years to evolve — long enough
						that Caroline Herschel could discover it in 1783, and long enough that its HR
						diagram looks very different from a young cluster.
					</p>
					<p>
						In the Pleiades, massive hot stars still dominate the upper main sequence because
						not enough time has passed for them to exhaust their hydrogen. In NGC 752, those
						same high-mass stars have already run out of fuel, swollen into red giants, and
						departed. The point where stars peel away from the main sequence —
						the <strong>main-sequence turn-off</strong> — has migrated downward to lower
						masses. A faint red giant branch now stands clearly above the remaining
						lower main sequence.
					</p>
					<p>
						This is why clusters are such powerful stellar clocks: because all the stars
						formed at the same time, the position of the turn-off tells you directly how long
						the cluster has been evolving.
					</p>
				</section>

				<section class="narrated-tour__chapter" data-step="omega-cen">
					<p class="narrated-tour__chapter-eyebrow">Step 8 · Globular cluster · Omega Centauri · 100 pc view</p>
					<h2 class="narrated-tour__chapter-title">An ancient population — and a few puzzling impostors</h2>
					<p>
						Finally we jump to Omega Centauri, the largest and brightest globular cluster in
						our sky — so unusual that it may be the stripped core of a small dwarf galaxy.
						Formed billions of years before the Sun, it is a completely different stellar
						environment: far older, denser, and dominated entirely by low-mass survivors.
						We widen the view to 100 parsecs so we capture a representative slice of this
						enormous cluster rather than just its core.
					</p>
					<p>
						The hot, massive end of the main sequence is gone because those stars exhausted
						their hydrogen long ago and have since faded into remnants. What remains is a
						very low turn-off, a prominent giant branch, and — at the faint end — a sparse
						scattering of the white dwarf remnants left over from stellar deaths spread
						across billions of years.
					</p>
					<p>
						Look carefully for a handful of points sitting <em>above</em> the turn-off and
						bluer than the giant branch. These are <strong>blue stragglers</strong>: stars
						that appear younger than the rest of the cluster. They should not exist — by now
						every star massive enough to sit there ought to have evolved away. The leading
						explanation is that they were rejuvenated by stealing mass from a companion star,
						or by two stars merging outright. Dense globular clusters like Omega Centauri are
						exactly the environment where such collisions and close encounters happen, making
						blue stragglers a signature feature of an ancient, crowded stellar population.
					</p>
				</section>

				<div class="narrated-tour__spacer" aria-hidden="true"></div>
			</div>

			<div class="narrated-tour__viewer-col">
				<div class="narrated-tour__viewer-sticky">
					<div class="narrated-tour__nav">
						<button type="button" class="narrated-tour__nav-button" data-step-fly="all-stars">All sky</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="inner-plane">Inner disc</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="out-of-plane">High lat</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="local-volume">Local</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="away-volume">+200 pc</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="pleiades">Pleiades</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="ngc-752">NGC 752</button>
						<button type="button" class="narrated-tour__nav-button" data-step-fly="omega-cen">ω Cen</button>
					</div>

					<div
						class="narrated-tour__viewer-shell hr-tour__viewer-shell"
						data-hr-diagram-viewer
						data-topic="hr-diagram-lesson"
						data-show-hr="true"
					>
						<section class="hr-tour__pane">
							<div class="hr-tour__pane-head">
								<span class="tag">Star view</span>
							</div>
							<div class="hr-tour__space-view" data-hr-diagram-viewer-shell></div>
						</section>

						<section class="hr-tour__pane">
							<div class="hr-tour__pane-head">
								<span class="tag">HR diagram</span>
							</div>
							<canvas class="hr-tour__canvas" data-hr-diagram-viewer-hr aria-label="Live HR diagram"></canvas>
						</section>
					</div>

					<span class="narrated-tour__status" data-hr-tour-status>Loading…</span>
				</div>
			</div>
		</div>

		<section class="explore-section">
			<h2>What to compare across the full lesson</h2>
			<p>
				The same plot is doing two jobs at once: revealing stellar evolution and revealing the
				built-in limits of the data.
			</p>
			<div class="explore-grid">
				<article class="panel">
					<p class="panel__eyebrow">Bias</p>
					<h3>Moving the observer does not move the telescope</h3>
					<p>
						When you fly away from the Sun, you are not creating a brand-new Gaia survey from
						that location. You are reusing data collected from Earth, so faint stars can
						drop out because of how the data were collected even when the underlying stellar mix has
						changed very little.
					</p>
				</article>

				<article class="panel">
					<p class="panel__eyebrow">Youth</p>
					<h3>The Pleiades keep most of their stars near a young track</h3>
					<p>
						A young open cluster has had little time to evolve away from the main sequence.
						Its HR diagram is much tighter than the mixed-age field near the Sun.
					</p>
				</article>

				<article class="panel">
					<p class="panel__eyebrow">Age</p>
					<h3>NGC 752 shows the turn-off shifting downward</h3>
					<p>
						Compared with the younger Pleiades population, NGC 752 has already lost its
						hottest main-sequence stars. That missing upper end is the signature of a much
						more evolved cluster.
					</p>
				</article>

				<article class="panel">
					<p class="panel__eyebrow">Extremes</p>
					<h3>Omega Centauri is a very old population in a very different setting</h3>
					<p>
						A globular cluster pushes the lesson to its oldest end-state: dense, ancient, and
						depleted of massive stars. Its diagram should feel nothing like the local field or
						the young star-forming region.
					</p>
				</article>
			</div>
		</section>

		<section class="body-section prose">
			<h2>Artefacts in the diagram</h2>
			<p>
				If you look carefully at the cool edge of the diagram, you will notice features that
				come not from stellar physics but from how the data is processed.
			</p>

			<h3>The ~2 700 K wall</h3>
			<p>
				The main sequence appears to hit a hard vertical wall at around 2 700 K. This is real,
				but it comes from the way the data are processed, not from a physical boundary. Most
				faint red stars here do not have a spectroscopic temperature estimate. For those stars the
				pipeline falls
				back to converting the Gaia BP&ndash;RP colour index to an effective temperature using the
				<a
					href="https://github.com/Found-in-Space/pipeline/blob/main/src/foundinspace/pipeline/common/photometry.py"
					class="link--gold"
				>
					Ballesteros (2012) relation
				</a>.
				That conversion clamps the B&ndash;V colour index at 2.5 to avoid singularities, which
				maps every star redder than BP&ndash;RP&nbsp;&asymp;&nbsp;3.0 to the same temperature of
				roughly 2 725 K. The result is a hard pile-up at that value. Real M dwarfs extend to
				cooler temperatures, but this dataset cannot distinguish them.
			</p>

			<h3>The 5 800 K default</h3>
			<p>
				A small number of stars have no usable temperature from any source: no Gaia
				spectroscopic estimate, no BP&ndash;RP colour, no B&ndash;V. The pipeline
				<a
					href="https://github.com/Found-in-Space/pipeline/blob/main/src/foundinspace/pipeline/gaia/photometry.py"
					class="link--gold"
				>
					assigns these a default of 5 800 K
				</a>
				(roughly solar). You may notice a faint vertical streak at the Sun's temperature. That
				is these default-temperature stars landing at the same x-coordinate. The effect is subtle
				but visible when a larger local volume is loaded.
			</p>
		</section>

		<section class="gaia-note">
			<div class="panel panel--accent">
				<p class="panel__eyebrow">Beyond this lesson</p>
				<h3>Gaia made the modern HR diagram a precision tool</h3>
				<p>
					Gaia has measured positions, distances, and colours for nearly two billion stars. In
					those enormous HR diagrams, astronomers can see fine structure invisible in smaller
					surveys: split white-dwarf sequences, crystallisation pile-ups, and the unresolved
					binary sequence just above the main sequence. Each faint ridge is another piece of
					stellar physics hiding in a scatter plot.
				</p>
			</div>
		</section>

		<TopicNext topics={nextTopics} />

		<MadeByKaj />
	</main>
</Layout>

<script>
	import {
		DEFAULT_HR_MAG_LIMIT,
		DEFAULT_HR_VOLUME_RADIUS,
		INNER_GALACTIC_PLANE_TARGET_PC,
		mountHrDiagramViewer,
	} from '../../../scripts/hr-diagram-viewer.js';
	import { createJourneyGraph } from '../../../scripts/journey-builder.js';
	import { setupNarratedTour } from '../../../scripts/narrated-tour.js';
	import {
		OMEGA_CEN_CENTER_PC,
		PLEIADES_CENTER_PC,
		SOLAR_ORIGIN_PC,
		buildOrbitalInsertRoute,
	} from '@found-in-space/skykit';

	const tourRoot = document.querySelector('[data-hr-tour]');
	const viewerRoot = document.querySelector('[data-hr-diagram-viewer]');
	const statusEl = document.querySelector('[data-hr-tour-status]');
	const chapters = tourRoot?.querySelectorAll('.narrated-tour__chapter[data-step]') ?? [];
	const navButtons = tourRoot?.querySelectorAll('[data-step-fly]') ?? [];
	const OFFSET_SAMPLE_PC = { x: 200, y: 0, z: 0 };
	const LESSON_VOLUME_RADIUS_PC = DEFAULT_HR_VOLUME_RADIUS;
	const OMEGA_CEN_VOLUME_RADIUS_PC = 100;
	const PLEIADES_ORBIT_RADIUS_PC = 10;
	const PLEIADES_ANGULAR_SPEED = 0.22;
	const PLEIADES_STANDARD_TRAVEL_TIME_SECS = 5;
	const NGC_752_ORBIT_RADIUS_PC = 10;
	const NGC_752_ANGULAR_SPEED = 0.22;
	const NGC_752_STANDARD_TRAVEL_TIME_SECS = 5;
	const OMEGA_CEN_ORBIT_RADIUS_PC = 60;
	const OMEGA_CEN_ANGULAR_SPEED = 0.08;
	const OMEGA_CEN_TRAVEL_TIME_SECS = 15;
	const OMEGA_CEN_DECELERATION = 2.5;
	const OMEGA_CEN_ORBIT_NORMAL = [0, 1, 0];
	const PRELOAD_STARTUP_DELAY_MS = 600;
	const PRELOAD_STAGGER_MS = 150;
	const PRELOAD_TIMEOUT_MS = 2_500;

	const NGC_752_CENTER_PC = { x: 303.7, y: 167.0, z: 269.3 };

	const ARCTURUS_PC = { x: -8.8, y: -5.9, z: 3.7 };
	const ACRUX_PC = { x: -44.4, y: -5.2, z: -88.0 };

	function getLastPoint(points = [], fallback = null) {
		return Array.isArray(points) && points.length > 0 ? points[points.length - 1] : fallback;
	}

	function reversePath(points = []) {
		return [...points].reverse();
	}

	function buildOrbitArrivalAction(centerPc, radius, angularSpeed) {
		return {
			type: 'orbit',
			centerPc,
			radius,
			angularSpeed,
		};
	}

	function buildCanonicalOrbitalRoute(startObserverPc, {
		centerPc,
		orbitRadius,
		angularSpeed,
		durationSecs,
		deceleration = 2.5,
		orbitNormal = null,
	} = {}) {
		return buildOrbitalInsertRoute(startObserverPc, {
			centerPc,
			orbitRadius,
			angularSpeed,
			durationSecs,
			deceleration,
			...(Array.isArray(orbitNormal) ? { orbitNormal } : {}),
			sampleStepSecs: 1 / 24,
		});
	}

	function createTransition(fromSceneId, toSceneId, transition = {}) {
		return {
			fromSceneId,
			toSceneId,
			...transition,
		};
	}

	function createPolylineTransition(fromSceneId, toSceneId, {
		pathPoints,
		arrivalAction = null,
		preloadAnchorObserverPc = null,
		...transition
	} = {}) {
		return createTransition(fromSceneId, toSceneId, {
			travelPathPc: pathPoints,
			travelPathArrivalAction: arrivalAction,
			preloadAnchorObserverPc,
			prependStartObserverToTravelPath: true,
			...transition,
		});
	}

	function reverseRadiusProfile(profile = []) {
		return [...profile]
			.map((point) => ({
				...point,
				progress: 1 - point.progress,
			}))
			.reverse();
	}

	const AWAY_VOLUME_FORWARD_PATH_PC = [SOLAR_ORIGIN_PC, OFFSET_SAMPLE_PC];
	const AWAY_VOLUME_REVERSE_PATH_PC = reversePath(AWAY_VOLUME_FORWARD_PATH_PC);

	const PLEIADES_ROUTE_TEMPLATE = buildCanonicalOrbitalRoute(OFFSET_SAMPLE_PC, {
		centerPc: PLEIADES_CENTER_PC,
		orbitRadius: PLEIADES_ORBIT_RADIUS_PC,
		angularSpeed: PLEIADES_ANGULAR_SPEED,
		durationSecs: PLEIADES_STANDARD_TRAVEL_TIME_SECS,
	});
	const PLEIADES_FORWARD_PATH_PC = PLEIADES_ROUTE_TEMPLATE?.points ?? [];
	const PLEIADES_ROUTE_ANCHOR_PC = getLastPoint(PLEIADES_FORWARD_PATH_PC, {
		x: PLEIADES_CENTER_PC.x + PLEIADES_ORBIT_RADIUS_PC,
		y: PLEIADES_CENTER_PC.y,
		z: PLEIADES_CENTER_PC.z,
	});
	const PLEIADES_REVERSE_PATH_PC = reversePath(PLEIADES_FORWARD_PATH_PC);

	const HYADES_ROUTE_TEMPLATE = buildCanonicalOrbitalRoute(PLEIADES_ROUTE_ANCHOR_PC, {
		centerPc: NGC_752_CENTER_PC,
		orbitRadius: NGC_752_ORBIT_RADIUS_PC,
		angularSpeed: NGC_752_ANGULAR_SPEED,
		durationSecs: NGC_752_STANDARD_TRAVEL_TIME_SECS,
	});
	const HYADES_FORWARD_PATH_PC = HYADES_ROUTE_TEMPLATE?.points ?? [];
	const HYADES_ROUTE_ANCHOR_PC = getLastPoint(HYADES_FORWARD_PATH_PC, {
		x: NGC_752_CENTER_PC.x + NGC_752_ORBIT_RADIUS_PC,
		y: NGC_752_CENTER_PC.y,
		z: NGC_752_CENTER_PC.z,
	});
	const HYADES_REVERSE_PATH_PC = reversePath(HYADES_FORWARD_PATH_PC);

	const OMEGA_CEN_ROUTE_TEMPLATE = buildCanonicalOrbitalRoute(HYADES_ROUTE_ANCHOR_PC, {
		centerPc: OMEGA_CEN_CENTER_PC,
		orbitRadius: OMEGA_CEN_ORBIT_RADIUS_PC,
		angularSpeed: OMEGA_CEN_ANGULAR_SPEED,
		durationSecs: OMEGA_CEN_TRAVEL_TIME_SECS,
		deceleration: OMEGA_CEN_DECELERATION,
		orbitNormal: OMEGA_CEN_ORBIT_NORMAL,
	});
	const OMEGA_CEN_FORWARD_PATH_PC = OMEGA_CEN_ROUTE_TEMPLATE?.points ?? [];
	const OMEGA_CEN_ROUTE_ANCHOR_PC = getLastPoint(OMEGA_CEN_FORWARD_PATH_PC, {
		x: OMEGA_CEN_CENTER_PC.x + OMEGA_CEN_ORBIT_RADIUS_PC,
		y: OMEGA_CEN_CENTER_PC.y,
		z: OMEGA_CEN_CENTER_PC.z,
	});
	const OMEGA_CEN_REVERSE_PATH_PC = reversePath(OMEGA_CEN_FORWARD_PATH_PC);

	const OMEGA_CEN_TRAVEL_RADIUS_PROFILE = [
		{ progress: 0, radiusPc: LESSON_VOLUME_RADIUS_PC },
		{ progress: 0.55, radiusPc: LESSON_VOLUME_RADIUS_PC },
		{ progress: 0.72, radiusPc: 40 },
		{ progress: 0.84, radiusPc: 60 },
		{ progress: 0.93, radiusPc: 80 },
		{ progress: 1, radiusPc: OMEGA_CEN_VOLUME_RADIUS_PC },
	];
	const OMEGA_CEN_RETURN_RADIUS_PROFILE = reverseRadiusProfile(OMEGA_CEN_TRAVEL_RADIUS_PROFILE);

	const SCENES = {
		'all-stars': {
			observerPc: SOLAR_ORIGIN_PC,
			targetPc: INNER_GALACTIC_PLANE_TARGET_PC,
			mode: 0,
			magLimit: DEFAULT_HR_MAG_LIMIT,
		},
		'inner-plane': {
			observerPc: SOLAR_ORIGIN_PC,
			targetPc: ACRUX_PC,
			mode: 2,
			magLimit: DEFAULT_HR_MAG_LIMIT,
		},
		'out-of-plane': {
			observerPc: SOLAR_ORIGIN_PC,
			targetPc: ARCTURUS_PC,
			mode: 2,
			magLimit: DEFAULT_HR_MAG_LIMIT,
		},
		'local-volume': {
			observerPc: SOLAR_ORIGIN_PC,
			targetPc: ARCTURUS_PC,
			mode: 1,
			radius: LESSON_VOLUME_RADIUS_PC,
			volumeRenderStrategy: 'strict',
		},
		'away-volume': {
			observerPc: OFFSET_SAMPLE_PC,
			targetPc: SOLAR_ORIGIN_PC,
			mode: 1,
			radius: LESSON_VOLUME_RADIUS_PC,
			travelTimeSecs: 4,
			volumeRenderStrategy: 'progressive',
			dwellMs: 4_000,
			recenterSpeed: 0.05,
		},
		'pleiades': {
			targetPc: PLEIADES_CENTER_PC,
			orbitCenter: PLEIADES_CENTER_PC,
			mode: 1,
			radius: LESSON_VOLUME_RADIUS_PC,
			orbitRadius: PLEIADES_ORBIT_RADIUS_PC,
			angularSpeed: PLEIADES_ANGULAR_SPEED,
			travelTimeSecs: PLEIADES_STANDARD_TRAVEL_TIME_SECS,
			volumeRenderStrategy: 'progressive',
			dwellMs: 5_000,
			recenterSpeed: 0.06,
		},
		'ngc-752': {
			targetPc: NGC_752_CENTER_PC,
			orbitCenter: NGC_752_CENTER_PC,
			mode: 1,
			radius: LESSON_VOLUME_RADIUS_PC,
			orbitRadius: NGC_752_ORBIT_RADIUS_PC,
			angularSpeed: NGC_752_ANGULAR_SPEED,
			travelTimeSecs: NGC_752_STANDARD_TRAVEL_TIME_SECS,
			volumeRenderStrategy: 'progressive',
			dwellMs: 5_000,
			recenterSpeed: 0.06,
		},
		'omega-cen': {
			targetPc: OMEGA_CEN_CENTER_PC,
			orbitCenter: OMEGA_CEN_CENTER_PC,
			mode: 1,
			radius: OMEGA_CEN_VOLUME_RADIUS_PC,
			orbitRadius: OMEGA_CEN_ORBIT_RADIUS_PC,
			angularSpeed: OMEGA_CEN_ANGULAR_SPEED,
			travelTimeSecs: OMEGA_CEN_TRAVEL_TIME_SECS,
			deceleration: OMEGA_CEN_DECELERATION,
			orbitNormal: OMEGA_CEN_ORBIT_NORMAL,
			volumeRenderStrategy: 'progressive',
			dwellMs: 6_000,
			recenterSpeed: 0.04,
		},
	};

	const TRANSITIONS = [
		createTransition('all-stars', 'inner-plane'),
		createTransition('inner-plane', 'all-stars'),
		createTransition('inner-plane', 'out-of-plane'),
		createTransition('out-of-plane', 'inner-plane'),
		createTransition('out-of-plane', 'local-volume'),
		createTransition('local-volume', 'out-of-plane'),
		createPolylineTransition('local-volume', 'away-volume', {
			pathPoints: AWAY_VOLUME_FORWARD_PATH_PC,
			travelTimeSecs: 4,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			preloadAnchorObserverPc: SOLAR_ORIGIN_PC,
			dwellMs: 4_000,
			recenterSpeed: 0.05,
		}),
		createPolylineTransition('away-volume', 'local-volume', {
			pathPoints: AWAY_VOLUME_REVERSE_PATH_PC,
			travelTimeSecs: 4,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			preloadAnchorObserverPc: OFFSET_SAMPLE_PC,
			dwellMs: 4_000,
			recenterSpeed: 0.05,
		}),
		createPolylineTransition('away-volume', 'pleiades', {
			pathPoints: PLEIADES_FORWARD_PATH_PC,
			arrivalAction:
				PLEIADES_ROUTE_TEMPLATE?.arrivalAction
				?? buildOrbitArrivalAction(
					PLEIADES_CENTER_PC,
					PLEIADES_ORBIT_RADIUS_PC,
					PLEIADES_ANGULAR_SPEED,
				),
			travelTimeSecs: PLEIADES_STANDARD_TRAVEL_TIME_SECS,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			preloadAnchorObserverPc: OFFSET_SAMPLE_PC,
			dwellMs: 5_000,
			recenterSpeed: 0.06,
		}),
		createPolylineTransition('pleiades', 'away-volume', {
			pathPoints: PLEIADES_REVERSE_PATH_PC,
			travelTimeSecs: PLEIADES_STANDARD_TRAVEL_TIME_SECS,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			preloadAnchorObserverPc: PLEIADES_ROUTE_ANCHOR_PC,
			dwellMs: 4_000,
			recenterSpeed: 0.05,
		}),
		createPolylineTransition('pleiades', 'ngc-752', {
			pathPoints: HYADES_FORWARD_PATH_PC,
			arrivalAction:
				HYADES_ROUTE_TEMPLATE?.arrivalAction
				?? buildOrbitArrivalAction(
					NGC_752_CENTER_PC,
					NGC_752_ORBIT_RADIUS_PC,
					NGC_752_ANGULAR_SPEED,
				),
			travelTimeSecs: NGC_752_STANDARD_TRAVEL_TIME_SECS,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			preloadAnchorObserverPc: PLEIADES_ROUTE_ANCHOR_PC,
			dwellMs: 5_000,
			recenterSpeed: 0.06,
		}),
		createPolylineTransition('ngc-752', 'pleiades', {
			pathPoints: HYADES_REVERSE_PATH_PC,
			arrivalAction: buildOrbitArrivalAction(
				PLEIADES_CENTER_PC,
				PLEIADES_ORBIT_RADIUS_PC,
				PLEIADES_ANGULAR_SPEED,
			),
			travelTimeSecs: NGC_752_STANDARD_TRAVEL_TIME_SECS,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			preloadAnchorObserverPc: HYADES_ROUTE_ANCHOR_PC,
			dwellMs: 5_000,
			recenterSpeed: 0.06,
		}),
		createPolylineTransition('ngc-752', 'omega-cen', {
			pathPoints: OMEGA_CEN_FORWARD_PATH_PC,
			arrivalAction:
				OMEGA_CEN_ROUTE_TEMPLATE?.arrivalAction
				?? buildOrbitArrivalAction(
					OMEGA_CEN_CENTER_PC,
					OMEGA_CEN_ORBIT_RADIUS_PC,
					OMEGA_CEN_ANGULAR_SPEED,
				),
			travelTimeSecs: OMEGA_CEN_TRAVEL_TIME_SECS,
			travelRadiusPc: LESSON_VOLUME_RADIUS_PC,
			travelRadiusProfile: OMEGA_CEN_TRAVEL_RADIUS_PROFILE,
			preloadAnchorObserverPc: HYADES_ROUTE_ANCHOR_PC,
			dwellMs: 6_000,
			recenterSpeed: 0.04,
			deceleration: OMEGA_CEN_DECELERATION,
		}),
		createPolylineTransition('omega-cen', 'ngc-752', {
			pathPoints: OMEGA_CEN_REVERSE_PATH_PC,
			arrivalAction: buildOrbitArrivalAction(
				NGC_752_CENTER_PC,
				NGC_752_ORBIT_RADIUS_PC,
				NGC_752_ANGULAR_SPEED,
			),
			travelTimeSecs: OMEGA_CEN_TRAVEL_TIME_SECS,
			travelRadiusPc: OMEGA_CEN_VOLUME_RADIUS_PC,
			travelRadiusProfile: OMEGA_CEN_RETURN_RADIUS_PROFILE,
			preloadAnchorObserverPc: OMEGA_CEN_ROUTE_ANCHOR_PC,
			dwellMs: 5_000,
			recenterSpeed: 0.06,
			deceleration: OMEGA_CEN_DECELERATION,
		}),
	];

	const journey = createJourneyGraph({
		initialSceneId: 'all-stars',
		scenes: SCENES,
		transitions: TRANSITIONS,
	});

	if (tourRoot && viewerRoot) {
		mountHrDiagramViewer(viewerRoot).then((viewer) => {
			let currentSceneId = journey.initialSceneId;

			setupNarratedTour({
				root: tourRoot,
				chapters,
				navButtons,
				getChapterId(chapter) {
					return chapter.dataset.step;
				},
				getNavButtonId(button) {
					return button.dataset.stepFly;
				},
				activate(id) {
					const scene = journey.resolveSceneSpec(id, { fromSceneId: currentSceneId });
					if (scene) {
						currentSceneId = id;
						viewer.applyScene(scene).catch((err) => {
							console.error('[website:hr-diagram-tour]', err);
						});
					}
				},
				statusEl,
				initialId: journey.initialSceneId,
				desktopStatus: 'Scroll to travel from the Sun to clusters and compare the HR diagram.',
				phoneStatus: '',
			});

			viewer.scheduleScenePreloadBatch(journey.listResolvedTransitionSpecs(), {
				delayMs: PRELOAD_STARTUP_DELAY_MS,
				staggerMs: PRELOAD_STAGGER_MS,
				timeoutMs: PRELOAD_TIMEOUT_MS,
			});
		}).catch((err) => {
			console.error('[website:hr-diagram-tour]', err);
			if (statusEl) statusEl.textContent = err instanceof Error ? err.message : String(err);
		});
	}
</script>

