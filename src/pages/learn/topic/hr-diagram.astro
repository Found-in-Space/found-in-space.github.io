		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.explore-grid h3 {
		color: var(--fis-text);
	}

	.explore-grid p {
		font-size: 0.96rem;
		line-height: 1.7;
	}

	/* ── Gaia note ─────────────────────────────────── */

	.gaia-note {
		max-width: 48rem;
		margin-bottom: 2rem;
	}

	.gaia-note h3 {
		margin: 0 0 0.65rem;
		font-size: 1.4rem;
		color: var(--fis-text);
	}

	.gaia-note p {
		line-height: 1.75;
	}

	/* ── Responsive ────────────────────────────────── */

	@media (max-width: 1024px) {
		.controls-inner {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.controls-secondary {
			min-width: 0;
		}
	}

	@media (max-width: 900px) {
		.viewer-panels {
			grid-template-columns: 1fr;
		}

		.viewer-shell,
		.hr-canvas {
			height: clamp(22rem, 50vh, 36rem);
		}

		.explore-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			padding-top: 2.2rem;
		}

		h1 {
			font-size: clamp(2.2rem, 12vw, 3.6rem);
		}

		.viewer-section {
			margin-left: -1.5rem;
			margin-right: -1.5rem;
		}
	}
</style>
