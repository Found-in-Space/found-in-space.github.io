---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import MadeByKaj from '../../components/MadeByKaj.astro';

const basePath = import.meta.env.BASE_URL;
const hrDiagramPath = `${basePath}learn/topic/hr-diagram/`;
const starClustersPath = `${basePath}learn/topic/star-clusters/`;
const radioBubblePath = `${basePath}learn/topic/radio-bubble/`;
const nextStepsPath = `${basePath}learn/next-steps/`;
---

<Layout
	title="Learn | Found in Space"
	description="Turn curiosity into understanding with clear astronomical explainers and structured learning journeys."
>
	<SiteHeader section="Learn" />

	<main class="page">
		<header class="hero">
			<p class="eyebrow">Classroom Mode</p>
			<h1>Learn the nearby stars</h1>
			<p class="lede">
				Found in Space is designed as a structured educational platform. Here you can find
				concise astronomical concepts and guided journeys that connect what you see in the night
				sky to the real 3D structure of the galaxy.
			</p>
		</header>

		<section class="section-grid">
			<article class="panel panel--featured">
				<div class="panel__content">
					<p class="panel__eyebrow">First lesson</p>
					<h2>The Hertzsprung-Russell diagram</h2>
					<p>
						One of astronomy's most powerful maps — plotting temperature against luminosity to
						reveal how stars are grouped, how they age, and what the solar neighbourhood is
						actually made of. Built on a live 3D star viewer using real Gaia data.
					</p>
					<a href={hrDiagramPath} class="button button--primary">Open the lesson</a>
				</div>
			</article>

			<article class="panel panel--featured">
				<div class="panel__content">
					<p class="panel__eyebrow">Lesson</p>
					<h2>Star clusters: families of stars</h2>
					<p>
						Stars are born in groups. Fly between real clusters — from stellar nurseries
						to ancient globulars — to see how age, gravity, and the galaxy shape stellar
						families.
					</p>
					<a href={starClustersPath} class="button button--primary">Open the lesson</a>
				</div>
			</article>

			<article class="panel panel--featured">
				<div class="panel__content">
					<p class="panel__eyebrow">Lesson</p>
					<h2>The radio bubble</h2>
					<p>
						How far have Earth's radio signals travelled? Fly outside humanity's
						electromagnetic footprint to see how small it really is — and discover
						that our signals are about to reach the nearest star cluster.
					</p>
					<a href={radioBubblePath} class="button button--primary">Open the lesson</a>
				</div>
			</article>
		</section>

		<section class="next-steps-section">
			<article class="panel panel--accent">
				<div class="panel__content">
					<p class="panel__eyebrow">For students and the curious</p>
					<h2>Next steps</h2>
					<p>
						Once you've worked through the lessons, these are the questions that come
						after — open research topics you can investigate using real Gaia data, the
						tools on this site, and your own analysis. Each one is a starting point, not
						an answer.
					</p>
					<a href={nextStepsPath} class="button button--ghost">Browse research topics →</a>
				</div>
			</article>
		</section>

		<section class="notes">
			<div class="notes__intro">
				<p class="eyebrow">Our approach</p>
				<h2>Questions over answers.</h2>
			</div>
			<div class="notes__body">
				<p>
					Every lesson in the Learn section is built on real measurements from ESA's Gaia mission.
					The aim is clarity without sacrificing precision — moving from simple visual metaphors
					to the actual data astronomers use to map our corner of the Milky Way.
				</p>
				<p>
					More lessons are in development. The HR diagram is a working example of the format:
					a short explainer, a live 3D viewer, and a guided tour of what the data shows.
				</p>
			</div>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<style>
	.hero {
		padding: 2rem 0 3rem;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	.lede {
		max-width: 44rem;
		font-size: 1.18rem;
	}

	.section-grid {
		grid-template-columns: 1fr;
		gap: 1.5rem;
		max-width: 52rem;
	}

	.panel {
		display: flex;
		flex-direction: column;
		padding: 2rem;
	}

	h2 {
		margin: 0 0 1rem;
		font-size: 1.85rem;
		line-height: 1.1;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.panel p {
		margin: 0 0 1.5rem;
		line-height: 1.7;
		color: var(--fis-text-soft);
	}

	.next-steps-section {
		max-width: 52rem;
		margin-bottom: 2rem;
	}

	.notes {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 3rem;
		padding: 4rem 0;
		border-top: 1px solid var(--fis-line);
	}

	.notes__intro h2 {
		font-size: 2.2rem;
		line-height: 1.05;
		max-width: 12ch;
	}

	.notes__body p + p {
		margin-top: 1.25rem;
	}

	.notes__body p {
		line-height: 1.75;
		font-size: 1.1rem;
		color: var(--fis-text-soft);
	}

	@media (max-width: 960px) {
		.notes {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
