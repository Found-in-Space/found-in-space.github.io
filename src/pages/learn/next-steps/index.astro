---
import Layout from '../../../layouts/Layout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import MadeByKaj from '../../../components/MadeByKaj.astro';

const basePath = import.meta.env.BASE_URL;

const proposals = [
	{
		slug: 'why-orion-and-the-pleiades-can-look-elongated',
		title: 'Why do the Orion Nebula stars and the Pleiades look elongated?',
		summary:
			'When nearby stellar groupings are rendered in three dimensions from Gaia distances, ' +
			'familiar structures can appear stretched along the line of sight — sometimes pointing ' +
			'straight back at the Sun. Is that real structure, or the geometry of the measurement?',
		tags: ['Gaia', 'Parallax uncertainty', 'Selection effects', 'Orion', 'Pleiades'],
	},
];
---

<Layout
	title="Next Steps | Learn | Found in Space"
	description="Proposed research topics for students — open questions you can investigate using real Gaia data, the Found in Space viewer, and the open pipeline."
>
	<SiteHeader section="Learn" />

	<main class="page">
		<header class="hero">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href={`${basePath}learn/`}>Learn</a>
				<span class="breadcrumb__sep" aria-hidden="true">›</span>
				<span>Next steps</span>
			</nav>
			<p class="eyebrow">For students and the curious</p>
			<h1>Next steps</h1>
			<p class="lede">
				The lessons teach the ideas. The viewer lets you explore them. These are the questions
				that come after — open problems you can investigate using real Gaia data, the tools
				on this site, and your own analysis. Each one is a starting point, not an answer.
			</p>
		</header>

		<section class="proposals" aria-label="Research topics">
			{proposals.map((p) => (
				<a class="proposal-card" href={`${basePath}learn/next-steps/${p.slug}/`}>
					<div class="proposal-card__body">
						<p class="proposal-card__label">Research topic</p>
						<h2>{p.title}</h2>
						<p>{p.summary}</p>
						<span class="proposal-card__cta">Read the brief →</span>
					</div>
					<div class="proposal-card__tags">
						{p.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</a>
			))}
		</section>

		<section class="notes">
			<div class="notes__intro">
				<p class="eyebrow">What these are</p>
				<h2>Guided starting points, not prescribed answers.</h2>
			</div>
			<div class="notes__body">
				<p>
					Each topic sets out a question that arises naturally from working with real
					astronomical data. It explains why the question matters, why it is harder than it
					looks, and suggests concrete tests or analyses a student could carry out.
				</p>
				<p>
					They assume familiarity with the ideas covered in the
					<a href={`${basePath}learn/`}>Learn</a> section — particularly how Gaia measures
					distances, what selection effects are, and how to think about uncertainty. If
					those ideas are new, start there.
				</p>
			</div>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<style>
	.hero {
		padding: 2rem 0 3rem;
		max-width: 52rem;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		margin: 0 0 1.5rem;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h2 {
		margin: 0 0 0.75rem;
		font-size: 1.55rem;
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--fis-text);
	}

	.lede {
		max-width: 44rem;
		font-size: 1.18rem;
		line-height: 1.75;
		color: var(--fis-text-soft);
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 1.5rem;
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.breadcrumb a {
		color: var(--fis-gold);
		text-decoration-color: rgba(242, 200, 121, 0.35);
	}

	.breadcrumb__sep {
		opacity: 0.4;
	}

	/* ── Proposal cards ──────────────────────────── */

	.proposals {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		max-width: 52rem;
		margin-bottom: 4rem;
	}

	.proposal-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 2rem;
		background: var(--fis-panel-strong, var(--fis-panel));
		border: 1px solid rgba(242, 200, 121, 0.18);
		border-radius: var(--fis-radius);
		backdrop-filter: blur(10px);
		box-shadow: var(--fis-shadow);
		text-decoration: none;
		transition:
			border-color 160ms ease,
			transform 160ms ease;
	}

	.proposal-card:hover {
		border-color: rgba(242, 200, 121, 0.35);
		transform: translateY(-3px);
	}

	.proposal-card__label {
		margin: 0 0 0.5rem;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fis-gold);
	}

	.proposal-card__body p {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--fis-text-soft);
	}

	.proposal-card__cta {
		display: block;
		margin-top: 1.25rem;
		font-size: 0.95rem;
		color: var(--fis-gold);
		text-decoration-color: rgba(242, 200, 121, 0.35);
	}

	.proposal-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.tag {
		padding: 0.2rem 0.65rem;
		border-radius: 999px;
		background: rgba(141, 183, 255, 0.07);
		border: 1px solid rgba(141, 183, 255, 0.14);
		font-size: 0.78rem;
		color: var(--fis-text-soft);
		font-family: var(--fis-font-ui);
	}

	/* ── Notes ────────────────────────────────────── */

	.notes {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 3rem;
		padding: 4rem 0;
		border-top: 1px solid var(--fis-line);
		margin-bottom: 2rem;
	}

	.notes__intro h2 {
		margin: 0;
		font-size: 2.2rem;
		line-height: 1.05;
		max-width: 14ch;
	}

	.notes__body p {
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.75;
		color: var(--fis-text-soft);
	}

	.notes__body p + p {
		margin-top: 1.25rem;
	}

	.notes__body a {
		color: var(--fis-gold);
		text-decoration-color: rgba(242, 200, 121, 0.4);
	}

	@media (max-width: 960px) {
		.notes {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
