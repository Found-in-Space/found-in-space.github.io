---
interface Props {
	topics: Array<{ slug: string; title: string }>;
}

const { topics } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<section class="topic-next">
	<div class="panel">
		<p class="panel__eyebrow">What to read next</p>
		<div class="topic-next__grid">
			{
				topics.map((topic) => (
					<a href={`${basePath}learn/${topic.slug}/`} class="topic-next__link">
						<h3>{topic.title}</h3>
						<span class="topic-next__arrow">→</span>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.topic-next {
		margin-top: 3rem;
	}

	.panel {
		padding: 1.45rem;
		background: var(--fis-panel);
		border: 1px solid var(--fis-line);
		border-radius: var(--fis-radius);
		backdrop-filter: blur(10px);
		box-shadow: var(--fis-shadow);
	}

	.panel__eyebrow {
		margin: 0 0 1rem;
		font-size: 0.8rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--fis-gold);
	}

	.topic-next__grid {
		display: grid;
		gap: 0.75rem;
	}

	.topic-next__link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		background: rgba(13, 22, 36, 0.4);
		border: 1px solid rgba(141, 183, 255, 0.08);
		border-radius: 1rem;
		text-decoration: none;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.topic-next__link:hover {
		transform: translateX(4px);
		border-color: rgba(242, 200, 121, 0.3);
		background: rgba(15, 28, 50, 0.7);
	}

	.topic-next__link h3 {
		margin: 0;
		font-size: 1.15rem;
		font-weight: 500;
		color: var(--fis-text);
	}

	.topic-next__arrow {
		font-size: 1.2rem;
		color: var(--fis-gold);
	}
</style>
