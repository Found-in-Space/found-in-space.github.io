---
import MadeByKaj from '../../components/MadeByKaj.astro';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const basePath = import.meta.env.BASE_URL;
const constellationPath = `${basePath}explore/constellations-and-3d-space/`;
---

<Layout
	title="Parallax | Found in Space"
	description="Shift the observing position around Orion with pointer or device motion and watch nearby stars move against the distant background."
>
	<SiteHeader section="Explore" />

	<main class="page">
		<section class="intro">
			<p class="eyebrow">Explore</p>
			<h1>Parallax</h1>
			<p class="lede">
				Parallax is the apparent shift in position caused by a change in viewpoint. Move across
				the canvas to shift Earth&rsquo;s position while the selected constellation stays centered
				&mdash; nearby stars slide more than distant ones, revealing the depth hiding inside a
				flat picture.
			</p>
		</section>

		<section class="viewer-section" id="viewer">
			<div class="viewer-controls">
				<label class="viewer-controls__label" for="parallax-constellation-select">Center on</label>
				<select
					id="parallax-constellation-select"
					class="viewer-controls__select"
					data-parallax-constellation
					disabled
				>
					<option value="">Loading constellations…</option>
				</select>
			</div>
			<div class="viewer-shell" data-constellation-viewer="parallax"></div>
			<p class="status">Status: <span data-viewer-status>Loading the parallax example…</span></p>
		</section>

		<section class="notes">
			<article class="panel">
				<p class="panel__eyebrow">What to notice</p>
				<h3>Not every star moves by the same amount</h3>
				<p>
					If all the stars were equally distant, they would shift together. The fact that they do
					not is the clue that depth is hiding inside the familiar flat picture.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Why it matters</p>
				<h3>Parallax is a measurement tool, not only a visual trick</h3>
				<p>
					In astronomy, parallax is one of the foundations of distance measurement. The same basic
					geometry that makes this page work also helps us map the nearby galaxy.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Try next</p>
				<h3>See it with free movement</h3>
				<p>
					The fly-through lets you navigate freely through the same stars. This page isolates the
					parallax effect so you can recognise it clearly before exploring at larger scale.
				</p>
				<p class="notes__link">
					<a href={constellationPath}>Open the constellation fly-through</a>
				</p>
			</article>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<script>
	import { mountConstellationViewer } from '../../scripts/examples/constellation-viewer.js';

	const mount = document.querySelector('[data-constellation-viewer]');
	const statusEl = document.querySelector('[data-viewer-status]');
	const constellationSelect = document.querySelector('[data-parallax-constellation]');

	if (mount) {
		mountConstellationViewer(mount, {
			mode: 'parallax',
			onStatus: (msg) => {
				if (statusEl) statusEl.textContent = msg;
			},
		}).then(({ constellations = [], setConstellation } = {}) => {
			if (!(constellationSelect instanceof HTMLSelectElement)) return;

			constellationSelect.innerHTML = '';
			for (const { iau, label } of constellations) {
				const option = document.createElement('option');
				option.value = iau;
				option.textContent = label;
				constellationSelect.append(option);
			}

			const defaultIau = constellations.some((entry) => entry.iau === 'Ori')
				? 'Ori'
				: constellations[0]?.iau;

			if (defaultIau) {
				constellationSelect.value = defaultIau;
				setConstellation?.(defaultIau);
			}

			constellationSelect.disabled = constellations.length === 0;
			constellationSelect.addEventListener('change', () => {
				setConstellation?.(constellationSelect.value);
			});
		}).catch((err) => {
			console.error('[website:parallax-mount]', err);
			if (statusEl) statusEl.textContent = err instanceof Error ? err.message : String(err);
			if (constellationSelect instanceof HTMLSelectElement) {
				constellationSelect.disabled = true;
				constellationSelect.innerHTML = '<option value="">Unable to load constellations</option>';
			}
		});
	}
</script>

<style>
	.intro {
		padding: 2rem 0 1.75rem;
	}

	h1,
	h3 {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		max-width: 8ch;
	}

	h3 {
		font-size: 1.35rem;
		line-height: 1.1;
		margin-bottom: 0.7rem;
	}

	p {
		margin: 0;
		line-height: 1.7;
		color: var(--fis-text-soft);
	}

	p + p {
		margin-top: 0.95rem;
	}

	/* ── Viewer ──────────────────────────────────── */

	.viewer-section {
		margin-left: -1.5rem;
		margin-right: -1.5rem;
	}

	.viewer-controls {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.8rem 1.5rem 0.65rem;
		background: rgba(2, 4, 11, 0.92);
		border-top: 1px solid var(--fis-line);
		border-bottom: 1px solid var(--fis-line);
	}

	.viewer-controls__label {
		font-family: var(--fis-font-ui);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fis-text-muted);
	}

	.viewer-controls__select {
		min-width: min(26rem, 100%);
		max-width: 100%;
		background-color: var(--fis-panel);
		color: var(--fis-text);
		border: 1px solid var(--fis-line-strong);
		border-radius: 0.6rem;
		padding: 0.38rem 0.62rem;
		font-family: var(--fis-font-ui);
		font-size: 0.92rem;
	}

	.viewer-controls__select:focus-visible {
		outline: 2px solid var(--fis-gold);
		outline-offset: 1px;
	}

	.viewer-controls__select:disabled {
		opacity: 0.65;
		cursor: not-allowed;
	}

	.viewer-shell {
		width: 100%;
		height: clamp(28rem, 72vh, 54rem);
		background:
			radial-gradient(circle at top, rgba(148, 220, 255, 0.08), transparent 20%),
			#02040b;
		touch-action: none;
		cursor: crosshair;
	}

	.status {
		padding: 0.75rem 1.5rem;
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.status span {
		color: var(--fis-blue);
	}

	/* ── Notes ───────────────────────────────────── */

	.notes {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.notes__link a {
		color: var(--fis-gold);
		text-decoration-color: var(--fis-gold-subtle);
	}

	/* ── Responsive ──────────────────────────────── */

	@media (max-width: 800px) {
		.notes {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			padding-top: 2.2rem;
		}

		.viewer-controls {
			flex-direction: column;
			align-items: flex-start;
			padding-left: 1rem;
			padding-right: 1rem;
		}

		.viewer-controls__select {
			width: 100%;
		}

		h1 {
			font-size: clamp(2.4rem, 13vw, 4rem);
		}
	}
</style>
