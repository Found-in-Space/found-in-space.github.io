    "video:radio-bubble:plates:test": "node scripts/render-radio-bubble-video.mjs --mode=preview --layout=landscape-1080p --fps=6 --seconds=2 --plates=all",
    "video:radio-bubble:final:4k": "node scripts/render-radio-bubble-video.mjs --mode=final --layout=landscape-4k",
    "video:radio-bubble:full": "npm run video:radio-bubble:final:4k",
