---
import MadeByKaj from '../../components/MadeByKaj.astro';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const basePath = import.meta.env.BASE_URL;
const constellationPath = `${basePath}explore/constellations-and-3d-space/`;
const debugPath = `${basePath}learn/parallax-debug/`;
---

<Layout
	title="Parallax | Found in Space"
	description="A SkyKit-powered parallax lesson that shifts the observing position around Orion with pointer or device motion."
>
	<SiteHeader section="Learn" />

	<main class="page">
		<section class="intro">
			<p class="eyebrow">Learn</p>
			<h1>Parallax</h1>
			<p class="lede">
				Parallax is the apparent shift in position caused by a change in viewpoint. Move across
				the canvas to shift Earth&rsquo;s position while Orion stays in view &mdash; nearby stars
				slide more than distant ones, revealing the depth hiding inside a flat picture.
			</p>
		</section>

		<section class="viewer-section" id="viewer">
			<div class="viewer-shell" data-example="parallax-viewer"></div>
		</section>

		<section class="controls-section">
			<div class="controls-inner">
				<div class="controls-primary">
					<p class="controls-heading">How to explore</p>
					<div class="nav-hints">
						<span class="nav-hint">Move pointer</span><span class="nav-sep">—</span><span class="nav-desc">shift Earth&rsquo;s position left or right</span>
						<span class="nav-hint">Touch drag</span><span class="nav-sep">—</span><span class="nav-desc">drag a finger left or right on mobile</span>
					</div>
					<p class="motion-tip">
						On a supported device you can also tilt the screen &mdash; tap <strong>Enable Device Motion</strong> below to try it.
					</p>
					<p class="meta-line">
						Input mode: <span data-parallax-mode>pointer</span>
					</p>
				</div>

				<div class="controls-secondary">
					<div class="control-group">
						<label for="parallax-offset">Observer offset</label>
						<div class="control-row">
							<input
								id="parallax-offset"
								data-parallax-offset
								type="range"
								min="0.02"
								max="1.0"
								step="0.01"
								value="1.0"
							/>
							<span class="control-value" data-parallax-offset-value>0.12 pc</span>
						</div>
					</div>
					<div class="controls-actions">
						<button type="button" class="button button--ghost" data-action="enable-motion" hidden>
							Enable Device Motion
						</button>
						<a class="button button--ghost" href={constellationPath}>Back to fly-through</a>
						<a class="button button--ghost" href={debugPath}>Motion debug</a>
					</div>
					<p class="status">Status: <span data-parallax-status>Loading the parallax example…</span></p>
				</div>
			</div>
		</section>

		<section class="notes">
			<article class="panel">
				<p class="panel__eyebrow">What to notice</p>
				<h3>Not every star moves by the same amount</h3>
				<p>
					If all the stars were equally distant, they would shift together. The fact that they do
					not is the clue that depth is hiding inside the familiar flat picture.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Why it matters</p>
				<h3>Parallax is a measurement tool, not only a visual trick</h3>
				<p>
					In astronomy, parallax is one of the foundations of distance measurement. The same basic
					geometry that makes this page work also helps us map the nearby galaxy.
				</p>
			</article>
			<article class="panel">
				<p class="panel__eyebrow">Try next</p>
				<h3>Compare it with free movement</h3>
				<p>
					The fly-through adds larger motion and open navigation. This page narrows the motion down
					to a single idea so you can recognise the effect before you see it in a bigger journey.
				</p>
				<p class="notes__link">
					<a href={constellationPath}>Open the constellation fly-through</a>
				</p>
			</article>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<script>
	import '../../scripts/examples/parallax-demo.js';
</script>

<script is:inline>
	(function () {
		var shell = document.querySelector('[data-example="parallax-viewer"]');
		if (!shell) return;

		// Prevent page scroll when touching inside the canvas
		shell.addEventListener('touchmove', function (e) { e.preventDefault(); }, { passive: false });
		shell.addEventListener('touchstart', function (e) { e.stopPropagation(); }, { passive: true });

		// Prevent arrow-key and space page-scroll while the mouse is over the canvas
		var overCanvas = false;
		shell.addEventListener('mouseenter', function () { overCanvas = true; });
		shell.addEventListener('mouseleave', function () { overCanvas = false; });

		document.addEventListener('keydown', function (e) {
			if (!overCanvas) return;
			if (
				e.key === 'ArrowUp' || e.key === 'ArrowDown' ||
				e.key === 'ArrowLeft' || e.key === 'ArrowRight' ||
				e.key === ' '
			) {
				e.preventDefault();
			}
		});
	})();
</script>

<style>
	.intro {
		padding: 2rem 0 1.75rem;
	}

	h1,
	h3 {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		max-width: 8ch;
	}

	h3 {
		font-size: 1.35rem;
		line-height: 1.1;
		margin-bottom: 0.7rem;
	}

	p {
		margin: 0;
		line-height: 1.7;
		color: var(--fis-text-soft);
	}

	p + p {
		margin-top: 0.95rem;
	}

	/* ── Viewer ──────────────────────────────────── */

	.viewer-section {
		margin-left: -1.5rem;
		margin-right: -1.5rem;
	}

	.viewer-shell {
		width: 100%;
		height: clamp(28rem, 72vh, 54rem);
		background:
			radial-gradient(circle at top, rgba(148, 220, 255, 0.08), transparent 20%),
			#02040b;
		touch-action: none;
		cursor: crosshair;
	}

	/* ── Controls section ────────────────────────── */

	.controls-section {
		padding: 1.5rem 0 1.75rem;
		border-bottom: 1px solid var(--fis-line);
		margin-bottom: 2rem;
	}

	.controls-inner {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 2.5rem;
		align-items: start;
	}

	.controls-heading {
		margin: 0 0 0.85rem;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fis-text-soft);
	}

	/* Navigation hints */

	.nav-hints {
		display: grid;
		grid-template-columns: auto auto 1fr;
		gap: 0.3rem 0.6rem;
		align-items: baseline;
		margin-bottom: 0.9rem;
	}

	.nav-hint {
		font-size: 0.9rem;
		color: var(--fis-text);
		font-family: var(--fis-font-ui);
	}

	.nav-sep {
		color: var(--fis-line-strong);
	}

	.nav-desc {
		font-size: 0.9rem;
		color: var(--fis-text-soft);
	}

	.motion-tip {
		font-size: 0.88rem;
		color: var(--fis-text-soft);
		max-width: 36rem;
		margin-bottom: 0.65rem;
	}

	.motion-tip strong {
		color: var(--fis-text);
		font-weight: 500;
	}

	.meta-line {
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.meta-line span {
		color: var(--fis-gold);
	}

	/* Secondary controls */

	.controls-secondary {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		min-width: 17rem;
	}

	.control-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	label {
		font-size: 0.88rem;
		color: var(--fis-text);
		font-family: var(--fis-font-ui);
	}

	.control-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.8rem;
		align-items: center;
	}

	input[type='range'] {
		width: 100%;
	}

	.control-value {
		min-width: 3.8rem;
		font-family: var(--fis-font-ui);
		color: var(--fis-gold);
		text-align: right;
	}

	.controls-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.status {
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.status span {
		color: var(--fis-blue);
	}

	/* ── Notes ───────────────────────────────────── */

	.notes {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.notes__link a {
		color: var(--fis-gold);
		text-decoration-color: rgba(242, 200, 121, 0.42);
	}

	/* ── Responsive ──────────────────────────────── */

	@media (max-width: 1024px) {
		.controls-inner {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.controls-secondary {
			min-width: 0;
		}
	}

	@media (max-width: 800px) {
		.notes {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			padding-top: 2.2rem;
		}

		h1 {
			font-size: clamp(2.4rem, 13vw, 4rem);
		}
	}
</style>
