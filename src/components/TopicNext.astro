---
interface Props {
	topics: Array<{ slug: string; title: string }>;
}

const { topics } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

{topics.length > 0 && (
	<section class="topic-next">
		<div class="panel">
			<p class="panel__eyebrow">What to read next</p>
			<div class="topic-next__grid">
				{
					topics.map((topic) => (
						<a href={`${basePath}learn/topic/${topic.slug}/`} class="topic-next__link">
							<h3>{topic.title}</h3>
							<span class="topic-next__arrow">→</span>
						</a>
					))
				}
			</div>
		</div>
	</section>
)}

<style>
	.topic-next {
		margin-top: 3rem;
	}

	.topic-next__grid {
		display: grid;
		gap: 0.75rem;
	}

	.topic-next__link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		background: rgba(13, 22, 36, 0.4);
		border: 1px solid rgba(141, 183, 255, 0.08);
		border-radius: 1rem;
		text-decoration: none;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.topic-next__link:hover {
		transform: translateX(4px);
		border-color: rgba(242, 200, 121, 0.3);
		background: rgba(15, 28, 50, 0.7);
	}

	.topic-next__link h3 {
		margin: 0;
		font-size: 1.15rem;
		font-weight: 500;
		color: var(--fis-text);
	}

	.topic-next__arrow {
		font-size: 1.2rem;
		color: var(--fis-gold);
	}
</style>
