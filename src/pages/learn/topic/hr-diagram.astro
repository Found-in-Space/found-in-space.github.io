		max-width: 48rem;
		padding: 2rem 0 0;
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 1.5rem;
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.breadcrumb a {
		color: var(--fis-gold);
		text-decoration-color: rgba(242, 200, 121, 0.35);
	}

	.breadcrumb__sep {
		opacity: 0.4;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.4rem, 6vw, 4.2rem);
		line-height: 1.02;
		max-width: 16ch;
	}

	h2 {
		font-size: 1.55rem;
		line-height: 1.1;
		margin-bottom: 0.85rem;
		color: var(--fis-text);
	}

	h3 {
		font-size: 1.3rem;
		line-height: 1.15;
		margin-bottom: 0.65rem;
	}

	p {
		margin: 0;
		line-height: 1.75;
		color: var(--fis-text-soft);
	}

	p + p {
		margin-top: 1rem;
	}

	/* ── Body text ─────────────────────────────────── */

	.body-section {
		max-width: 48rem;
		padding: 2.5rem 0 1rem;
	}

	.body-section h2 {
		margin-top: 2.5rem;
	}

	.body-section h2:first-child {
		margin-top: 0;
	}

	.body-section p {
		font-size: 1.1rem;
		line-height: 1.8;
		margin-bottom: 1.4rem;
	}

	.body-section em {
		color: var(--fis-text);
		font-style: italic;
	}

	.body-section strong {
		color: var(--fis-text);
		font-weight: 600;
	}

	.body-section .callout {
		margin: 2.5rem 0;
		padding: 1.8rem;
	}

	.body-section .callout h3 {
		margin: 0 0 0.65rem;
		font-size: 1.3rem;
		color: var(--fis-text);
	}

	.body-section .callout p {
		font-size: 1.02rem;
		line-height: 1.7;
		margin-bottom: 0;
	}

	/* ── Viewer ────────────────────────────────────── */

	.viewer-wrapper {
		margin-top: 1rem;
	}

	.viewer-section {
		margin-left: -1.5rem;
		margin-right: -1.5rem;
	}

	.viewer-panels {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
		gap: 1rem;
		padding: 0 1rem;
	}

	.viewer-shell {
		width: 100%;
		height: clamp(28rem, 64vh, 48rem);
		border-radius: var(--fis-radius);
		overflow: hidden;
		background:
			radial-gradient(circle at top, rgba(148, 220, 255, 0.08), transparent 20%),
			#02040b;
		touch-action: none;
		cursor: grab;
	}

	.viewer-shell:active {
		cursor: grabbing;
	}

	.hr-canvas {
		width: 100%;
		height: clamp(28rem, 64vh, 48rem);
		background: rgba(1, 6, 16, 0.92);
		border: 1px solid rgba(242, 200, 121, 0.25);
		border-radius: var(--fis-radius);
	}

	/* ── Controls ──────────────────────────────────── */

	.controls-section {
		padding: 1.25rem 0 1.5rem;
		border-bottom: 1px solid var(--fis-line);
		margin-bottom: 2.5rem;
	}

	.controls-inner {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 2.5rem;
		align-items: start;
	}

	.controls-heading {
		margin: 0 0 0.85rem;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fis-text-soft);
	}

	.nav-hints {
		display: grid;
		grid-template-columns: auto auto 1fr;
		gap: 0.3rem 0.6rem;
		align-items: baseline;
		margin-bottom: 1rem;
	}

	.nav-hint {
		font-size: 0.9rem;
		color: var(--fis-text);
		font-family: var(--fis-font-ui);
	}

	.nav-sep {
		color: var(--fis-line-strong);
	}

	.nav-desc {
		font-size: 0.9rem;
		color: var(--fis-text-soft);
	}

	.key-guide {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.key-row {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		flex-wrap: wrap;
	}

	kbd {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.9em;
		padding: 0.18em 0.45em;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 5px;
		background: rgba(255, 255, 255, 0.05);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8rem;
		color: var(--fis-text);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.08), inset 0 -1px 0 rgba(0, 0, 0, 0.4);
		line-height: 1;
	}

	.key-label {
		font-size: 0.82rem;
		color: var(--fis-text-soft);
		margin-left: 0.2rem;
	}

	.key-sep {
		font-size: 0.82rem;
		color: var(--fis-text-soft);
		margin: 0 0.1rem;
	}

	.controls-secondary {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		min-width: 14rem;
		align-items: flex-start;
	}

	.controls-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.status {
		font-size: 0.88rem;
		color: var(--fis-text-soft);
	}

	.status span {
		color: var(--fis-gold);
	}

	/* ── Explore section ───────────────────────────── */

	.explore-section {
		max-width: 48rem;
	}

	.explore-section > p {
		font-size: 1.1rem;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.explore-grid {
