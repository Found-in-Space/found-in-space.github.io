---
import MadeByKaj from '../../components/MadeByKaj.astro';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const basePath = import.meta.env.BASE_URL;
const parallaxPath = `${basePath}learn/parallax/`;
---

<Layout
	title="Parallax Sensor Debug | Found in Space"
	description="A sensor-only sandbox for tuning parallax device motion without the star field."
>
	<SiteHeader section="Debug" />

	<main class="page">
		<section class="intro">
			<p class="eyebrow">Parallax Sandbox</p>
			<h1>Device Motion Debug</h1>
			<p class="lede">
				This page removes the stars completely and shows only the live motion input. The goal is to
				make landscape swaps, early clipping, and odd calibration visible before we feed the values
				back into the Orion lesson.
			</p>
			<div class="intro__actions">
				<button type="button" class="button button--primary" data-action="enable-debug-motion">
					Enable Device Motion
				</button>
				<button type="button" class="button button--ghost" data-action="recenter-debug-motion">
					Recenter
				</button>
				<a class="button button--ghost" href={parallaxPath}>Back to parallax</a>
			</div>
			<p class="status">
				Status: <span data-debug-status>Waiting for device motion to be enabled.</span>
			</p>
		</section>

		<section class="dashboard">
			<article class="panel panel--hero">
				<p class="panel__eyebrow">Normalized output</p>
				<h2>Screen-space motion</h2>
				<div class="pad">
					<div class="pad__grid" aria-hidden="true"></div>
					<div class="pad__dot" data-debug-pad-dot aria-hidden="true"></div>
				</div>
				<div class="axis-grid">
					<div class="axis-card">
						<div class="axis-card__row">
							<span>Normalized X</span>
							<strong data-debug-value="normalized-x">0.0000</strong>
						</div>
						<div class="axis-bar">
							<div class="axis-bar__marker" data-debug-bar="normalized-x"></div>
						</div>
					</div>
					<div class="axis-card">
						<div class="axis-card__row">
							<span>Normalized Y</span>
							<strong data-debug-value="normalized-y">0.0000</strong>
						</div>
						<div class="axis-bar">
							<div class="axis-bar__marker" data-debug-bar="normalized-y"></div>
						</div>
					</div>
				</div>
			</article>

			<article class="panel">
				<p class="panel__eyebrow">Device input</p>
				<h2>Raw sensor angles</h2>
				<div class="metric-list">
					<div class="metric">
						<div class="metric__row">
							<span>Alpha</span>
							<strong data-debug-value="raw-alpha">0.00</strong>
						</div>
					</div>
					<div class="metric">
						<div class="metric__row">
							<span>Beta</span>
							<strong data-debug-value="raw-beta">0.00</strong>
						</div>
						<div class="axis-bar">
							<div class="axis-bar__marker" data-debug-bar="raw-beta"></div>
						</div>
					</div>
					<div class="metric">
						<div class="metric__row">
							<span>Gamma</span>
							<strong data-debug-value="raw-gamma">0.00</strong>
						</div>
						<div class="axis-bar">
							<div class="axis-bar__marker" data-debug-bar="raw-gamma"></div>
						</div>
					</div>
				</div>
			</article>

			<article class="panel">
				<p class="panel__eyebrow">Intermediate values</p>
				<h2>Projection and clipping</h2>
				<div class="metric-list">
					<div class="metric">
						<div class="metric__row">
							<span>Projected X</span>
							<strong data-debug-value="projected-x">0.0000</strong>
						</div>
						<div class="axis-bar">
							<div class="axis-bar__marker" data-debug-bar="projected-x"></div>
						</div>
					</div>
					<div class="metric">
						<div class="metric__row">
							<span>Projected Y</span>
							<strong data-debug-value="projected-y">0.0000</strong>
						</div>
						<div class="axis-bar">
							<div class="axis-bar__marker" data-debug-bar="projected-y"></div>
						</div>
					</div>
					<div class="metrics-inline">
						<p>Clamped X: <strong data-debug-value="clamped-x">0.0000</strong></p>
						<p>Clamped Y: <strong data-debug-value="clamped-y">0.0000</strong></p>
						<p>Saturated X: <strong data-debug-value="saturated-x">no</strong></p>
						<p>Saturated Y: <strong data-debug-value="saturated-y">no</strong></p>
					</div>
				</div>
			</article>

			<article class="panel">
				<p class="panel__eyebrow">Orientation state</p>
				<h2>Calibration details</h2>
				<dl class="debug-list">
					<div>
						<dt>Phase</dt>
						<dd data-debug-phase>idle</dd>
					</div>
					<div>
						<dt>Screen orientation</dt>
						<dd data-debug-orientation-type>unknown</dd>
					</div>
					<div>
						<dt>Screen angle</dt>
						<dd data-debug-value="screen-angle-deg">0.0 deg</dd>
					</div>
					<div>
						<dt>Baseline right</dt>
						<dd data-debug-value="baseline-right">0.0000, 0.0000, 0.0000</dd>
					</div>
					<div>
						<dt>Baseline up</dt>
						<dd data-debug-value="baseline-up">0.0000, 0.0000, 0.0000</dd>
					</div>
					<div>
						<dt>Current normal</dt>
						<dd data-debug-value="current-normal">0.0000, 0.0000, 0.0000</dd>
					</div>
				</dl>
			</article>
		</section>

		<MadeByKaj />
	</main>
</Layout>

<script>
	import '../../scripts/examples/parallax-sensor-debug.js';
</script>

<style>
	.intro {
		padding: 2rem 0 1.5rem;
	}

	h1,
	h2 {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.8rem, 7vw, 5.2rem);
		line-height: 0.94;
		max-width: 10ch;
	}

	h2 {
		font-size: 1.7rem;
		line-height: 1.05;
		margin-bottom: 0.75rem;
	}

	.lede {
		max-width: 46rem;
		margin: 1.2rem 0 0;
		font-size: clamp(1.08rem, 2vw, 1.28rem);
		line-height: 1.7;
		color: var(--fis-text-soft);
	}

	.intro__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.status {
		margin: 1.2rem 0 0;
		color: var(--fis-text-muted);
	}

	.dashboard {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem;
		margin-top: 2rem;
	}

	.panel {
		padding: 1.3rem;
		border-radius: 1.4rem;
		border: 1px solid rgba(141, 183, 255, 0.14);
		background:
			radial-gradient(circle at top, rgba(71, 108, 201, 0.16), transparent 55%),
			rgba(7, 15, 28, 0.82);
		box-shadow: var(--fis-shadow);
	}

	.panel--hero {
		grid-column: span 2;
	}

	.pad {
		position: relative;
		aspect-ratio: 1;
		max-width: 20rem;
		margin-top: 1rem;
		border-radius: 1.6rem;
		border: 1px solid rgba(141, 183, 255, 0.18);
		background:
			radial-gradient(circle at center, rgba(73, 120, 255, 0.14), transparent 60%),
			rgba(4, 10, 20, 0.92);
		overflow: hidden;
	}

	.pad__grid::before,
	.pad__grid::after {
		content: '';
		position: absolute;
		background: rgba(141, 183, 255, 0.18);
	}

	.pad__grid::before {
		top: 50%;
		left: 0;
		right: 0;
		height: 1px;
		transform: translateY(-50%);
	}

	.pad__grid::after {
		left: 50%;
		top: 0;
		bottom: 0;
		width: 1px;
		transform: translateX(-50%);
	}

	.pad__dot {
		position: absolute;
		width: 1rem;
		height: 1rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #f2c879, #8db7ff);
		box-shadow: 0 0 0 6px rgba(141, 183, 255, 0.12);
		transform: translate(-50%, -50%);
		left: 50%;
		top: 50%;
	}

	.axis-grid,
	.metric-list {
		display: grid;
		gap: 1rem;
		margin-top: 1rem;
	}

	.axis-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.axis-card,
	.metric {
		display: grid;
		gap: 0.45rem;
	}

	.axis-card__row,
	.metric__row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
	}

	.axis-card__row span,
	.metric__row span,
	.metrics-inline,
	.debug-list dt {
		color: var(--fis-text-muted);
	}

	.axis-bar {
		position: relative;
		height: 1.05rem;
		border-radius: 999px;
		background:
			linear-gradient(90deg, rgba(115, 158, 255, 0.08) 0%, rgba(115, 158, 255, 0.18) 50%, rgba(115, 158, 255, 0.08) 100%);
		border: 1px solid rgba(141, 183, 255, 0.12);
	}

	.axis-bar::before {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 1px;
		background: rgba(242, 200, 121, 0.45);
		transform: translateX(-50%);
	}

	.axis-bar__marker {
		position: absolute;
		top: 50%;
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 999px;
		background: #8db7ff;
		transform: translate(-50%, -50%);
		box-shadow: 0 0 0 3px rgba(141, 183, 255, 0.12);
	}

	.axis-bar__marker[data-saturated='true'] {
		background: #f2c879;
		box-shadow: 0 0 0 3px rgba(242, 200, 121, 0.18);
	}

	.metrics-inline {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem 1rem;
		font-size: 0.96rem;
	}

	.metrics-inline p,
	.debug-list dd,
	.debug-list dt {
		margin: 0;
	}

	.debug-list {
		display: grid;
		gap: 0.9rem;
		margin: 1rem 0 0;
	}

	.debug-list div {
		display: grid;
		gap: 0.2rem;
	}

	.debug-list dd {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace;
		font-size: 0.94rem;
		word-break: break-word;
	}

	@media (max-width: 900px) {
		.dashboard,
		.axis-grid {
			grid-template-columns: minmax(0, 1fr);
		}

		.panel--hero {
			grid-column: span 1;
		}
	}

	@media (max-width: 640px) {
		.page {
			padding-inline: 1rem;
		}

		.metrics-inline {
			grid-template-columns: minmax(0, 1fr);
		}
	}
</style>
